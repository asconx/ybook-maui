<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             x:Class="yBook.Views.ICalendar.AddCalendarPopup"
             BackgroundColor="#80000000">

    <Grid VerticalOptions="Center" HorizontalOptions="Center">

        <Frame WidthRequest="300"
               Padding="15"
               CornerRadius="12"
               BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">

            <VerticalStackLayout Spacing="10">

                <Entry Placeholder="Wpisz nazwę synchronizacji"
                   x:Name="NameEntry"
                   TextChanged="OnNameChanged"/>

                <Entry Placeholder="Link eksportu"
                   x:Name="ExportLinkEntry"
                   IsReadOnly="True"/>

                <Entry Placeholder="Import URL 1"
                       x:Name="Import1Entry"/>

                <Entry Placeholder="Import URL 2"
                       x:Name="Import2Entry"/>

                <Entry Placeholder="Dodatkowe pole"
                       x:Name="ExtraEntry"/>


                <Button Text="Zapisz"
                        Clicked="OnSaveClicked"/>

                <Button Text="Anuluj"
                        Clicked="OnCancelClicked"/>

            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>
