<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ctrl="clr-namespace:yBook.Controls"
             x:Class="yBook.Views.Blokady.RezerwacjeOnlinePage">

    <Grid RowDefinitions="60,*">

        <!-- HEADER -->
        <ctrl:PageHeader Grid.Row="0"
                         Title="Rezerwacje Online"
                         Icon="🌐"
                         ShowBack="True"/>

        <Grid Grid.Row="1"
              RowDefinitions="Auto,*"
              BackgroundColor="{AppThemeBinding Light=#F4F6F9, Dark=#121212}">

            <!-- PASEK GÓRNY: licznik + przycisk Dodaj -->
            <Grid Grid.Row="0"
                  Padding="16,12"
                  ColumnDefinitions="Auto,Auto,*,Auto"
                  BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}">

                <Label Grid.Column="0"
                       Text="Rezerwacje online"
                       FontSize="15"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#263238, Dark=#ECEFF1}"
                       VerticalOptions="Center"/>

                <!-- Licznik (pill) -->
                <Border Grid.Column="1"
                        BackgroundColor="#F57C00"
                        StrokeShape="RoundRectangle 10"
                        Padding="7,2"
                        Margin="8,0,0,0"
                        VerticalOptions="Center">
                    <Label x:Name="LblLicznik"
                           Text="0"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="White"/>
                </Border>

                <!-- Przycisk dodaj -->
                <Button Grid.Column="3"
                        Text="dodaj"
                        BackgroundColor="#1A1A1A"
                        TextColor="White"
                        FontSize="13"
                        CornerRadius="20"
                        Padding="18,0"
                        HeightRequest="36"
                        Clicked="OnDodajClicked"/>
            </Grid>

            <!-- TABELA -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Spacing="0">

                    <!-- NAGŁÓWEK TABELI -->
                    <Grid Padding="16,10"
                          ColumnDefinitions="44,*,90,90,140,130,90,*"
                          BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#1A1A2E}">

                        <BoxView Grid.ColumnSpan="8"
                                 VerticalOptions="End"
                                 HeightRequest="1"
                                 BackgroundColor="#E0E0E0"/>

                        <!-- pusta kolumna (ikony akcji) -->
                        <Label Grid.Column="0" Text="" />

                        <Label Grid.Column="1"
                               Text="Slug"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#607D8B, Dark=#78909C}"/>

                        <Label Grid.Column="2"
                               Text="Grupowanie"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#607D8B, Dark=#78909C}"/>

                        <Label Grid.Column="3"
                               Text="Czcionka"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#607D8B, Dark=#78909C}"/>

                        <Label Grid.Column="4"
                               Text="Początkowy termin"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#607D8B, Dark=#78909C}"/>

                        <Label Grid.Column="5"
                               Text="Nazwa przedpłaty"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#607D8B, Dark=#78909C}"/>

                        <Label Grid.Column="6"
                               Text="Opcja faktury"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#607D8B, Dark=#78909C}"/>

                        <Label Grid.Column="7"
                               Text="Rozliczenie"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#607D8B, Dark=#78909C}"/>

                    </Grid>

                    <!-- WIERSZE -->
                    <CollectionView x:Name="RezerwacjeList"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>

                                <!-- Wiersz tabeli -->
                                <Grid Padding="16,0"
                                      ColumnDefinitions="44,*,90,90,140,130,90,*"
                                      MinimumHeightRequest="52">

                                    <!-- Separator dolny -->
                                    <BoxView Grid.ColumnSpan="8"
                                             VerticalOptions="End"
                                             HeightRequest="1"
                                             BackgroundColor="#F0F0F0"/>

                                    <!-- Kolumna 0: ikony akcji -->
                                    <HorizontalStackLayout Grid.Column="0"
                                                           Spacing="4"
                                                           VerticalOptions="Center">

                                        <!-- Edytuj -->
                                        <Border BackgroundColor="#17A2B8"
                                                StrokeShape="RoundRectangle 6"
                                                WidthRequest="28" HeightRequest="28">
                                            <Label Text="✏️"
                                                   FontSize="13"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnEdytujTapped"
                                                                          CommandParameter="{Binding .}"/>
                                                </Label.GestureRecognizers>
                                            </Label>
                                        </Border>

                                        <!-- Usuń -->
                                        <Border BackgroundColor="#FFA500"
                                                StrokeShape="RoundRectangle 6"
                                                WidthRequest="28" HeightRequest="28">
                                            <Label Text="🗑️"
                                                   FontSize="13"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnUsunTapped"
                                                                          CommandParameter="{Binding .}"/>
                                                </Label.GestureRecognizers>
                                            </Label>
                                        </Border>

                                    </HorizontalStackLayout>

                                    <!-- Kolumna 1: Slug -->
                                    <Label Grid.Column="1"
                                           Text="{Binding Slug}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light=#263238, Dark=#ECEFF1}"
                                           VerticalOptions="Center"/>

                                    <!-- Kolumna 2: Grupowanie (pill) -->
                                    <Border Grid.Column="2"
                                            StrokeShape="RoundRectangle 12"
                                            Stroke="#BDBDBD"
                                            BackgroundColor="Transparent"
                                            Padding="10,3"
                                            VerticalOptions="Center"
                                            HorizontalOptions="Start">
                                        <Label Text="{Binding GrupowanieLabel}"
                                               FontSize="12"
                                               TextColor="{AppThemeBinding Light=#455A64, Dark=#90A4AE}"/>
                                    </Border>

                                    <!-- Kolumna 3: Czcionka -->
                                    <Label Grid.Column="3"
                                           Text="{Binding Czcionka}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light=#263238, Dark=#ECEFF1}"
                                           VerticalOptions="Center"/>

                                    <!-- Kolumna 4: Termin (pill z obramowaniem) -->
                                    <Border Grid.Column="4"
                                            StrokeShape="RoundRectangle 12"
                                            Stroke="#80BDBDBD"
                                            BackgroundColor="Transparent"
                                            Padding="8,3"
                                            VerticalOptions="Center"
                                            HorizontalOptions="Start">
                                        <Label Text="{Binding TerminLabel}"
                                               FontSize="11"
                                               TextColor="{AppThemeBinding Light=#607D8B, Dark=#78909C}"/>
                                    </Border>

                                    <!-- Kolumna 5: Nazwa przedpłaty -->
                                    <Label Grid.Column="5"
                                           Text="{Binding NazwaPrzedplaty}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light=#263238, Dark=#ECEFF1}"
                                           VerticalOptions="Center"/>

                                    <!-- Kolumna 6: Opcja faktury (pill) -->
                                    <Border Grid.Column="6"
                                            StrokeShape="RoundRectangle 12"
                                            Stroke="#BDBDBD"
                                            BackgroundColor="Transparent"
                                            Padding="10,3"
                                            VerticalOptions="Center"
                                            HorizontalOptions="Start">
                                        <Label Text="{Binding OpcjaFakturyLabel}"
                                               FontSize="12"
                                               TextColor="{AppThemeBinding Light=#455A64, Dark=#90A4AE}"/>
                                    </Border>

                                    <!-- Kolumna 7: Rozliczenie -->
                                    <Label Grid.Column="7"
                                           Text="{Binding Rozliczenie}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light=#263238, Dark=#ECEFF1}"
                                           VerticalOptions="Center"/>

                                </Grid>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Stan pusty -->
                    <VerticalStackLayout x:Name="EmptyState"
                                         IsVisible="False"
                                         Padding="0,60"
                                         HorizontalOptions="Center"
                                         Spacing="8">
                        <Label Text="🌐" FontSize="48" HorizontalOptions="Center"/>
                        <Label Text="Brak rezerwacji online"
                               FontSize="15" FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="#90A4AE"/>
                        <Label Text="Naciśnij dodaj aby dodać pierwszą."
                               FontSize="13"
                               HorizontalOptions="Center"
                               TextColor="#B0BEC5"/>
                    </VerticalStackLayout>

                    <!-- Stopka: Wierszy na stronie -->
                    <Grid Padding="16,10"
                          ColumnDefinitions="*,Auto,Auto,Auto,Auto"
                          BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}">

                        <BoxView Grid.ColumnSpan="5"
                                 VerticalOptions="Start"
                                 HeightRequest="1"
                                 BackgroundColor="#E0E0E0"/>

                        <Label Grid.Column="1"
                               Text="Wierszy na stronie:"
                               FontSize="12"
                               TextColor="#90A4AE"
                               VerticalOptions="Center"/>

                        <Border Grid.Column="2"
                                Margin="8,0"
                                StrokeShape="RoundRectangle 4"
                                Stroke="#E0E0E0"
                                Padding="6,2">
                            <Picker x:Name="WierszePicker"
                                    FontSize="12"
                                    WidthRequest="55"
                                    SelectedIndexChanged="OnWierszeChanged">
                                <Picker.Items>
                                    <x:String>15</x:String>
                                    <x:String>30</x:String>
                                    <x:String>50</x:String>
                                </Picker.Items>
                            </Picker>
                        </Border>

                        <Label Grid.Column="3"
                               x:Name="LblStopka"
                               Text="1–0 z 0"
                               FontSize="12"
                               TextColor="#90A4AE"
                               VerticalOptions="Center"/>

                    </Grid>

                </VerticalStackLayout>
            </ScrollView>

        </Grid>
    </Grid>
</ContentPage>
