<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="yBook.Views.Ceny.UslugiOplaty"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>

		<!-- ============================= -->
		<!--            CUSTOMS            -->
		<!-- ============================= -->
		<Style x:Key="ColHeader" TargetType="Label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontAttributes" Value="Bold"/>
        </Style>

        <Style x:Key="ColCell" TargetType="Label">
            <Setter Property="FontSize" Value="12"/>
        </Style>

		<Style x:Key="CustomBorder" TargetType="Border">
			<Setter Property="Stroke" Value="#5FA8A8"/>
			<Setter Property="BackgroundColor" Value="#EAF6F6"/>
			<Setter Property="StrokeShape" Value="RoundRectangle 20"/>
			<Setter Property="Padding" Value="1"/>
		</Style>

		<Style x:Key="CustomText" TargetType="Label">
			<Setter Property="TextColor" Value="Black"/>
			<Setter Property="FontSize" Value="11"/>
		</Style>

		<Style x:Key="CustomTextBold" TargetType="Label">
			<Setter Property="TextColor" Value="Black"/>
			<Setter Property="FontSize" Value="11"/>
			<Setter Property="FontAttributes" Value="Bold"/>
		</Style>

	</ContentPage.Resources>

    <Grid RowDefinitions="60,Auto,*" BackgroundColor="#F5F5F5">

        <!-- ============================= -->
        <!--            HEADER             -->
		<!-- ============================= -->
		<Grid Grid.Row="0" Padding="12">
            <Grid ColumnDefinitions="*,Auto">

                <HorizontalStackLayout Spacing="8">
                    <Label Text="Usługi i opłaty"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="Black"/>

                    <Border BackgroundColor="#F5A623"
                            StrokeShape="RoundRectangle 10"
                            Padding="6,2">
                        <Label x:Name="LblCount"
                               Text="0"
                               FontSize="11"
                               TextColor="Black"/>
                    </Border>
                </HorizontalStackLayout>

                <Border Grid.Column="1"
                        BackgroundColor="#F5A623"
                        StrokeShape="RoundRectangle 20"
                        Padding="16,8">
                    <Label Text="dodaj"
                           TextColor="Black"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDodajClicked"/>
                    </Border.GestureRecognizers>
                </Border>

            </Grid>
        </Grid>

		<!-- ============================= -->
		<!--            FILTRY             -->
		<!-- ============================= -->
		<ScrollView Grid.Row="1" Orientation="Horizontal">
            <HorizontalStackLayout Spacing="10" Padding="12">

                <!-- TYP -->
                <Border Stroke="Black"
                        StrokeShape="RoundRectangle 20"
                        Padding="14,8">
                    <Label x:Name="LblTyp"
                           Text="Typ"
                           TextColor="Black"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTypTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- SEARCH -->
				<Border Stroke="Black"
                        StrokeShape="RoundRectangle 20"
                        Padding="10,5"
                        MinimumWidthRequest="150">
                    <Entry x:Name="Search"
                           Placeholder="Szukaj"
                           TextChanged="OnSearchChanged"/>
                </Border>

            </HorizontalStackLayout>
        </ScrollView>

		<!-- ============================= -->
		<!--            TABELA             -->
		<!-- ============================= -->
		<Grid Grid.Row="2" RowDefinitions="Auto,*"
              BackgroundColor="White">

            <!-- _____________________ -->
            <!--        HEADER         -->
			<ScrollView Orientation="Horizontal">
				<Grid ColumnDefinitions="80,120,120,150,200,120,120,150,200"
                      Padding="12,8">
					<Label Grid.Column="1" Text="Nazwa" Style="{StaticResource CustomTextBold}"/>
					<Label Grid.Column="2" Text="Rodzaj" Style="{StaticResource CustomTextBold}"/>
					<Label Grid.Column="3" Text="Typ" Style="{StaticResource CustomTextBold}"/>
					<Label Grid.Column="4" Text="Cena" Style="{StaticResource CustomTextBold}"/>
					<Label Grid.Column="5" Text="Data od" Style="{StaticResource CustomTextBold}"/>
					<Label Grid.Column="6" Text="Data do" Style="{StaticResource CustomTextBold}"/>
					<Label Grid.Column="7" Text="Opis" Style="{StaticResource CustomTextBold}"/>
                </Grid>
            </ScrollView>

			<!-- _____________________ -->
			<!--        LISTA          -->
			<CollectionView Grid.Row="1" x:Name="Lista">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid RowDefinitions="Auto,1">

                            <ScrollView Orientation="Horizontal">
								<Grid ColumnDefinitions="80,120,120,150,200,120,120,150,200" Padding="12">

									<!-- DESTROY -->
									<Border Style="{StaticResource CustomBorder}" Grid.Column="0">
										<Label Text="Usuń"
										   Style="{StaticResource CustomText}"
										   HorizontalOptions="Center"
										   VerticalOptions="Center"/>
										<Border.GestureRecognizers>
											<TapGestureRecognizer Tapped="OnDeleteClicked"/>
										</Border.GestureRecognizers>
									</Border>
									<!-- Name -->
									<Border Style="{StaticResource CustomBorder}" Grid.Column="1">
										<Label Style="{StaticResource CustomText}" Text="{Binding Name}" />
									</Border>

									<!-- RODZAJ -->
									<Border Style="{StaticResource CustomBorder}" Grid.Column="2">
										<Label Style="{StaticResource CustomText}" Text="{Binding Rodzaj}" />
									</Border>

									<!-- TYP -->
									<Border Style="{StaticResource CustomBorder}" Grid.Column="3">
										<Label Style="{StaticResource CustomText}" Text="{Binding Typ}" />
									</Border>

									<!-- CENY -->
									<Border Style="{StaticResource CustomBorder}" Grid.Column="4">
										<VerticalStackLayout BindableLayout.ItemsSource="{Binding Ceny}">
											<BindableLayout.ItemTemplate>
												<DataTemplate>
													<Label Style="{StaticResource CustomText}" Text="{Binding .}" />
												</DataTemplate>
											</BindableLayout.ItemTemplate>
										</VerticalStackLayout>
									</Border>

									<!-- DataOd -->
									<Border Style="{StaticResource CustomBorder}" Grid.Column="5">
										<Label Style="{StaticResource CustomText}" Text="{Binding DataOd}" />
									</Border>

									<!-- DataDo -->
									<Border Style="{StaticResource CustomBorder}" Grid.Column="6">
										<Label Style="{StaticResource CustomText}" Text="{Binding DataDo}" />
									</Border>

									<!-- Opis -->
									<Border Style="{StaticResource CustomBorder}" Grid.Column="7">
										<Label Style="{StaticResource CustomText}" Text="{Binding Opis}" />
									</Border>

								</Grid>
                            </ScrollView>

                            <BoxView Grid.Row="1" HeightRequest="1" Color="#EEE"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </Grid>

    </Grid>
</ContentPage>