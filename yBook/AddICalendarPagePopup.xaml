<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="yBook.Views.ICalendar.AddCalendarPopup"
             BackgroundColor="#80000000">

    <Grid VerticalOptions="Center" HorizontalOptions="Center">

        <Frame WidthRequest="300"
               Padding="15"
               CornerRadius="12"
               BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">

            <VerticalStackLayout Spacing="10">

                <Entry Placeholder="Nazwa"
                       x:Name="NameEntry"
                       TextChanged="OnNameChanged"/>

                <Entry Placeholder="Export link"
                       x:Name="ExportLinkEntry"
                       IsReadOnly="True"/>

                <Entry Placeholder="Import 1"
                       x:Name="Import1Entry"/>

                <Entry Placeholder="Import 2"
                       x:Name="Import2Entry"/>

                <Entry Placeholder="Extra"
                       x:Name="ExtraEntry"/>

                <Button Text="Zapisz"
                        Clicked="OnSaveClicked"/>

                <Button Text="Anuluj"
                        Clicked="OnCancelClicked"/>

            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>>