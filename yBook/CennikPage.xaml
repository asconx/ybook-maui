<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ctrl="clr-namespace:yBook.Controls"
             x:Class="yBook.Views.Ceny.CennikPage"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="60,Auto,*"
          BackgroundColor="{AppThemeBinding Light=#F4F6F9, Dark=#121212}">

        <!-- ── Header ── -->
        <ctrl:PageHeader Grid.Row="0"
                         Title="Cenniki"
                         Icon="📋"
                         ShowBack="True"
                         x:Name="Header"/>

        <!-- ── Pasek akcji: licznik + dodaj + szukaj ── -->
        <Grid Grid.Row="1"
              ColumnDefinitions="Auto,Auto,*,Auto"
              Padding="12,10"
              BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
              ColumnSpacing="10">

            <!-- Licznik -->
            <Frame Grid.Column="0"
                   CornerRadius="12" Padding="8,4" HasShadow="False"
                   BackgroundColor="{AppThemeBinding Light=#1A2233, Dark=#0D1442}">
                <Label x:Name="LblLicznik"
                       Text="0"
                       FontSize="12" FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"/>
            </Frame>

            <!-- Przycisk dodaj -->
            <Frame Grid.Column="1"
                   CornerRadius="10" Padding="0" HasShadow="False"
                   BackgroundColor="{AppThemeBinding Light=#1A2233, Dark=#0D1442}">
                <Label Text="+ dodaj cennik"
                       FontSize="13" FontAttributes="Bold"
                       TextColor="White"
                       Padding="14,8"
                       HorizontalOptions="Center"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDodajClicked"/>
                    </Label.GestureRecognizers>
                </Label>
            </Frame>

            <!-- Wyszukiwarka -->
            <Border Grid.Column="2"
                    StrokeShape="RoundRectangle 10"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333}"
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}"
                    Padding="10,0"
                    HeightRequest="40">
                <SearchBar x:Name="SearchBar"
                           Placeholder="Szukaj..."
                           BackgroundColor="Transparent"
                           TextChanged="OnSearchChanged"
                           FontSize="13"/>
            </Border>

            <!-- Sortowanie priorytetu -->
            <Frame Grid.Column="3"
                   CornerRadius="10" Padding="10,6" HasShadow="False"
                   BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A2A}">
                <Label x:Name="LblSort"
                       Text="Priorytet ↑"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light=#555, Dark=#CCC}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSortToggle"/>
                    </Label.GestureRecognizers>
                </Label>
            </Frame>

        </Grid>

        <!-- ── Główna lista ── -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*">

            <!-- Nagłówek kolumn tabeli -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="60,*,90,100,180,*"
                  Padding="12,8,12,4"
                  BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                <BoxView Grid.ColumnSpan="6"
                         HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light=#E8EDF4, Dark=#2A2A2A}"
                         VerticalOptions="End"/>
                <Label Grid.Column="1" Text="NAZWA"
                       FontSize="11" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#9BAABB, Dark=#546E7A}"
                       />
                <Label Grid.Column="2" Text="CENA"
                       FontSize="11" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#9BAABB, Dark=#546E7A}"
                       />
                <Label Grid.Column="3" Text="PRIORYTET"
                       FontSize="11" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#9BAABB, Dark=#546E7A}"
                       />
                <Label Grid.Column="4" Text="ZAKRES CZASOWY"
                       FontSize="11" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#9BAABB, Dark=#546E7A}"
                       />
                <Label Grid.Column="5" Text="POKOJE"
                       FontSize="11" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#9BAABB, Dark=#546E7A}"
                       />
            </Grid>

            <!-- Lista cenników -->
            <CollectionView Grid.Row="1"
                            x:Name="CennikList"
                            SelectionMode="None">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0"
                              BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">

                            <!-- Separator -->
                            <BoxView HeightRequest="1"
                                     BackgroundColor="{AppThemeBinding Light=#F0F3F8, Dark=#1A1A2E}"
                                     VerticalOptions="End"/>

                            <Grid ColumnDefinitions="60,*,90,100,180,*"
                                  Padding="12,12">

                                <!-- Akcje: edytuj + usuń -->
                                <HorizontalStackLayout Grid.Column="0" Spacing="6" VerticalOptions="Center">
                                    <Frame CornerRadius="8" Padding="0" HasShadow="False"
                                           BackgroundColor="#2ABAAD22"
                                           WidthRequest="28" HeightRequest="28">
                                        <Label Text="✏️" FontSize="13"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnEdytujClicked"
                                                                      CommandParameter="{Binding Id}"/>
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </Frame>
                                    <Frame CornerRadius="8" Padding="0" HasShadow="False"
                                           BackgroundColor="#E0525222"
                                           WidthRequest="28" HeightRequest="28">
                                        <Label Text="🗑" FontSize="13"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnUsunClicked"
                                                                      CommandParameter="{Binding Id}"/>
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </Frame>
                                </HorizontalStackLayout>

                                <!-- Nazwa -->
                                <Label Grid.Column="1"
                                       Text="{Binding Nazwa}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#1A2233, Dark=#ECEFF1}"
                                       VerticalOptions="Center"
                                       LineBreakMode="TailTruncation"/>

                                <!-- Cena -->
                                <Label Grid.Column="2"
                                       Text="{Binding CenaStr}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=#1A2233, Dark=#ECEFF1}"
                                       VerticalOptions="Center"/>

                                <!-- Priorytet -->
                                <Label Grid.Column="3"
                                       Text="{Binding Priorytet}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=#1A2233, Dark=#ECEFF1}"
                                       VerticalOptions="Center"/>

                                <!-- Zakres czasowy — pill badge -->
                                <Frame Grid.Column="4"
                                       CornerRadius="20" Padding="10,4" HasShadow="False"
                                       BackgroundColor="#EAFAF9"
                                       HorizontalOptions="Start"
                                       VerticalOptions="Center">
                                    <Label Text="{Binding ZakresStr}"
                                           FontSize="11" FontAttributes="Bold"
                                           TextColor="#2ABAAD"
                                           LineBreakMode="NoWrap"/>
                                </Frame>

                                <!-- Pokoje — pierwszy badge + licznik -->
                                <HorizontalStackLayout Grid.Column="5"
                                                       Spacing="5" VerticalOptions="Center">
                                    <Frame CornerRadius="20" Padding="10,4" HasShadow="False"
                                           BackgroundColor="#EAFAF9">
                                        <Label Text="{Binding PierwszyPokoj}"
                                               FontSize="11" FontAttributes="Bold"
                                               TextColor="#2ABAAD"
                                               LineBreakMode="TailTruncation"
                                               MaximumWidthRequest="140"/>
                                    </Frame>
                                    <Frame CornerRadius="20" Padding="8,4" HasShadow="False"
                                           BackgroundColor="{AppThemeBinding Light=#F0F3F8, Dark=#2A2A2A}"
                                           IsVisible="{Binding MaWiecejPokoi}">
                                        <Label Text="{Binding DodatkowePokjeStr}"
                                               FontSize="11"
                                               TextColor="{AppThemeBinding Light=#7A8A9B, Dark=#90A4AE}"/>
                                    </Frame>
                                </HorizontalStackLayout>

                            </Grid>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                                         Spacing="8" Margin="0,60,0,0">
                        <Label Text="📋" FontSize="48" HorizontalOptions="Center"/>
                        <Label Text="Brak cenników" FontSize="16"
                               TextColor="#9E9E9E" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

            </CollectionView>

        </Grid>

        <!-- ── Drawer na wierzchu ── -->
        <ctrl:DrawerMenu Grid.Row="0" Grid.RowSpan="3"
                         x:Name="Drawer"
                         ZIndex="50"/>

        <!-- ── Modal: Dodaj / Edytuj ── -->
        <Grid x:Name="ModalOverlay"
              Grid.Row="0" Grid.RowSpan="3"
              IsVisible="False"
              ZIndex="100">

            <!-- Przyciemnienie tła -->
            <BoxView BackgroundColor="#80000000">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnModalOverlayTapped"/>
                </BoxView.GestureRecognizers>
            </BoxView>

            <!-- Panel modalu -->
            <Frame x:Name="ModalPanel"
                   CornerRadius="16" Padding="24" HasShadow="True"
                   BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   MaximumWidthRequest="500"
                   WidthRequest="460">
                <VerticalStackLayout Spacing="16">

                    <!-- Tytuł modalu -->
                    <Grid ColumnDefinitions="*,44">
                        <Label x:Name="LblModalTytul"
                               Text="Dodaj cennik"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#1A2233, Dark=#ECEFF1}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="✕"
                               FontSize="22"
                               TextColor="{AppThemeBinding Light=#9BAABB, Dark=#546E7A}"
                               HorizontalOptions="End"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnModalZamknijClicked"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <!-- Nazwa -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="NAZWA" FontSize="11" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#7A8A9B, Dark=#90A4AE}"
                               />
                        <Border StrokeShape="RoundRectangle 8"
                                Stroke="{AppThemeBinding Light=#DDE3EC, Dark=#333}"
                                BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#2A2A2A}"
                                Padding="12,0" HeightRequest="44">
                            <Entry x:Name="EntNazwa"
                                   Placeholder="np. Długi weekend sierpniowy"
                                   BackgroundColor="Transparent"
                                   FontSize="14"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Cena + Priorytet -->
                    <Grid ColumnDefinitions="*,12,*" ColumnSpacing="0">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="CENA (PLN)" FontSize="11" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#7A8A9B, Dark=#90A4AE}"
                                   />
                            <Border StrokeShape="RoundRectangle 8"
                                    Stroke="{AppThemeBinding Light=#DDE3EC, Dark=#333}"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#2A2A2A}"
                                    Padding="12,0" HeightRequest="44">
                                <Entry x:Name="EntCena"
                                       Placeholder="0.00"
                                       Keyboard="Numeric"
                                       BackgroundColor="Transparent"
                                       FontSize="14"/>
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="4">
                            <Label Text="PRIORYTET" FontSize="11" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#7A8A9B, Dark=#90A4AE}"
                                   />
                            <Border StrokeShape="RoundRectangle 8"
                                    Stroke="{AppThemeBinding Light=#DDE3EC, Dark=#333}"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#2A2A2A}"
                                    Padding="12,0" HeightRequest="44">
                                <Entry x:Name="EntPriorytet"
                                       Text="1"
                                       Keyboard="Numeric"
                                       BackgroundColor="Transparent"
                                       FontSize="14"/>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Data od + Data do -->
                    <Grid ColumnDefinitions="*,12,*" ColumnSpacing="0">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="DATA OD" FontSize="11" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#7A8A9B, Dark=#90A4AE}"
                                   />
                            <Border StrokeShape="RoundRectangle 8"
                                    Stroke="{AppThemeBinding Light=#DDE3EC, Dark=#333}"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#2A2A2A}"
                                    Padding="12,0" HeightRequest="44">
                                <DatePicker x:Name="DpOd"
                                            BackgroundColor="Transparent"
                                            FontSize="14"
                                            Format="yyyy-MM-dd"/>
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="4">
                            <Label Text="DATA DO" FontSize="11" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#7A8A9B, Dark=#90A4AE}"
                                   />
                            <Border StrokeShape="RoundRectangle 8"
                                    Stroke="{AppThemeBinding Light=#DDE3EC, Dark=#333}"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#2A2A2A}"
                                    Padding="12,0" HeightRequest="44">
                                <DatePicker x:Name="DpDo"
                                            BackgroundColor="Transparent"
                                            FontSize="14"
                                            Format="yyyy-MM-dd"/>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Pokoje (Entry wielowierszowy) -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="POKOJE (oddzielone przecinkiem)" FontSize="11" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#7A8A9B, Dark=#90A4AE}"
                               />
                        <Border StrokeShape="RoundRectangle 8"
                                Stroke="{AppThemeBinding Light=#DDE3EC, Dark=#333}"
                                BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#2A2A2A}"
                                Padding="12,8">
                            <Editor x:Name="EdtPokoje"
                                    Placeholder="np. Mały pokój 1, Pokój Standard 2"
                                    BackgroundColor="Transparent"
                                    FontSize="13"
                                    AutoSize="TextChanges"
                                    MinimumHeightRequest="44"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Błąd walidacji -->
                    <Label x:Name="LblBlad"
                           Text=""
                           FontSize="12"
                           TextColor="#E05252"
                           IsVisible="False"/>

                    <!-- Przyciski -->
                    <Grid ColumnDefinitions="*,12,*" ColumnSpacing="0">
                        <Frame Grid.Column="0"
                               CornerRadius="8" Padding="0" HasShadow="False"
                               BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#2A2A2A}"
                               BorderColor="{AppThemeBinding Light=#DDE3EC, Dark=#444}">
                            <Label Text="Anuluj"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#6B7A8D, Dark=#90A4AE}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   HeightRequest="44"
                                   HorizontalTextAlignment="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnModalZamknijClicked"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Frame>
                        <Frame Grid.Column="2"
                               CornerRadius="8" Padding="0" HasShadow="False"
                               BackgroundColor="#1A2233">
                            <Label Text="Zapisz"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   HeightRequest="44"
                                   HorizontalTextAlignment="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnZapiszClicked"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Frame>
                    </Grid>

                </VerticalStackLayout>
            </Frame>
        </Grid>

    </Grid>
</ContentPage>
