<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:yBook.Models;assembly=yBook"
             x:Class="yBook.Kasa"
             x:Name="ThisPage"
             BackgroundColor="#F1F6F7"
             Padding="16">

  <VerticalStackLayout Spacing="20">

    <!-- Top banner with start time and finish button -->
    <Frame BackgroundColor="#FCEAD9" CornerRadius="4" Padding="16" HasShadow="False">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Label Text="{Binding CurrentStartTime, StringFormat='{0:HH:mm}'}"
               FontAttributes="Bold"
               FontSize="24"
               TextColor="#111"
               VerticalOptions="Center"
               Grid.Column="0" />

        <Label Text="Czas rozpoczęcia zmiany."
               TextColor="#333"
               VerticalOptions="Center"
               Grid.Column="1"
               Margin="12,0" />

        <Button Text="zakończ zmianę"
                BackgroundColor="#79C4C7"
                TextColor="White"
                Padding="14,6"
                CornerRadius="20"
                HorizontalOptions="End"
                VerticalOptions="Center"
                Grid.Column="2"
                Clicked="OnFinishShiftClicked" />
      </Grid>
    </Frame>

    <!-- History card -->
    <Frame BackgroundColor="White" CornerRadius="4" Padding="0" HasShadow="False">
      <VerticalStackLayout>
        <Label Text="Historia zmian"
               Margin="12"
               FontFamily="Courier New"
               TextColor="#333" />

        <BoxView HeightRequest="1" Color="#EEE" />

        <StackLayout Padding="12">
          <HorizontalStackLayout Spacing="12">
            <!-- global actions can remain (optional) -->
            <Button Text="raport szczegółowy"
                    BackgroundColor="#F8E3E1"
                    TextColor="#333"
                    CornerRadius="20"
                    Padding="12,6" />

            <Button Text="raport uproszczony"
                    BackgroundColor="#F8E3E1"
                    TextColor="#333"
                    CornerRadius="20"
                    Padding="12,6" />
          </HorizontalStackLayout>
        </StackLayout>

        <BoxView HeightRequest="1" Color="#EEE" />

        <!-- Header row -->
        <Grid Padding="12" ColumnSpacing="8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <Label Text="Data rozpoczęcia zmiany" Grid.Column="0" FontAttributes="Bold" HorizontalOptions="Start" />
          <Label Text="Data zakończenia zmiany" Grid.Column="1" FontAttributes="Bold" HorizontalOptions="Start" />
          <Label Text="Gotówka" Grid.Column="2" FontAttributes="Bold" HorizontalOptions="End" />
          <Label Text="Przelewy" Grid.Column="3" FontAttributes="Bold" HorizontalOptions="End" />
        </Grid>

        <BoxView HeightRequest="1" Color="#EEE" />

        <!-- Collection of history items -->
        <CollectionView ItemsSource="{Binding Shifts}" SelectionMode="None">
          <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:CashierShift">
              <Grid Padding="12" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackLayout Orientation="Horizontal" Grid.Column="0" Spacing="8">
                  <Button Text="raport szczegółowy" 
                          BackgroundColor="#F8E3E1" 
                          TextColor="#333" 
                          CornerRadius="20" 
                          Padding="12,6"
                          Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ShowDetailedReportCommand}"
                          CommandParameter="{Binding .}" />
                </StackLayout>

                <Label Text="{Binding StartDateStr}" Grid.Column="0" HorizontalOptions="Start" Margin="120,0,0,0" />

                <Label Text="{Binding FinishDateStr}" Grid.Column="1" HorizontalOptions="Start" />

                <Label Text="{Binding BalanceCashStr}" Grid.Column="2" HorizontalOptions="End" />

                <Label Text="{Binding BalanceBankStr}" Grid.Column="3" HorizontalOptions="End" />
              </Grid>
            </DataTemplate>
          </CollectionView.ItemTemplate>
        </CollectionView>

        <BoxView HeightRequest="1" Color="#EEE" />

        <HorizontalStackLayout HorizontalOptions="End" Padding="12" Spacing="8">
          <Label Text="Wierszy na stronę:" VerticalOptions="Center" />
          <Picker WidthRequest="60" SelectedIndexChanged="OnPageSizeChanged">
            <Picker.Items>
              <x:String>5</x:String>
              <x:String>10</x:String>
            </Picker.Items>
          </Picker>
          <Label Text="{Binding PagingText}" VerticalOptions="Center" />
        </HorizontalStackLayout>

      </VerticalStackLayout>
    </Frame>

    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" VerticalOptions="Center" HorizontalOptions="Center" />

  </VerticalStackLayout>

</ContentPage>
