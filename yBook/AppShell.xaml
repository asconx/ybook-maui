<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:yBook"
       xmlns:auth="clr-namespace:yBook.Views.Auth"
       xmlns:finanse="clr-namespace:yBook.Views.Finanse"
       xmlns:ICalendar="clr-namespace:yBook.Views.ICalendar"
       xmlns:rabaty="clr-namespace:yBook.Views.Rabaty"
       xmlns:blokady="clr-namespace:yBook.Views.Blokady"
       xmlns:ustawienia="clr-namespace:yBook.Views.Ustawienia"
       x:Class="yBook.AppShell"
       Shell.NavBarIsVisible="False"
       FlyoutBehavior="Disabled">

    <!-- Strona logowania jako domyślna (sprawdzanie sesji w AppShell.xaml.cs) -->
    <ShellContent
        Title="Logowanie"
        ContentTemplate="{DataTemplate auth:LoginPage}"
        Route="LoginPage"/>

    <ShellContent
        Title="Pulpit"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage"/>

    <ShellContent
        Title="Rabaty"
        ContentTemplate="{DataTemplate rabaty:RabatyPage}"
        Route="RabatyPage"/>

    <ShellContent
        Title="Pokoje i apartamenty"
        ContentTemplate="{DataTemplate ustawienia:PokojePage}"
        Route="PokojePage"/>

    <ShellContent
        Title="Dane obiektu"
        ContentTemplate="{DataTemplate ustawienia:DaneObiektuPage}"
        Route="DaneObiektu"/>
    

</Shell>
