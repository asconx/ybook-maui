<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ctrl="clr-namespace:yBook.Controls"
             x:Class="yBook.Views.Finanse.KontaFinansowePage"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <Style x:Key="ColHeader" TargetType="Label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#555555, Dark=#90A4AE}"/>
            <Setter Property="VerticalOptions" Value="Center"/>
            <Setter Property="LineBreakMode" Value="TailTruncation"/>
        </Style>
        <Style x:Key="ColCell" TargetType="Label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#1A1A1A, Dark=#ECEFF1}"/>
            <Setter Property="VerticalOptions" Value="Center"/>
            <Setter Property="LineBreakMode" Value="TailTruncation"/>
        </Style>
        <Style x:Key="ColCellBold" TargetType="Label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="VerticalOptions" Value="Center"/>
            <Setter Property="LineBreakMode" Value="TailTruncation"/>
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="60, Auto, *"
          BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

        <ctrl:PageHeader Grid.Row="0"
                         Title="Konta finansowe"
                         Icon="🏦"
                         ShowBack="True"
                         x:Name="Header"/>

        <ScrollView Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalScrollBarVisibility="Never"
                    VerticalScrollBarVisibility="Never">

            <HorizontalStackLayout Spacing="12"
                                   Padding="12,10"
                                   VerticalOptions="Center">

                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                    <Label Text="Konta finansowe"
                           FontSize="15"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#ECEFF1}"/>
                    <Border StrokeShape="RoundRectangle 10"
                            BackgroundColor="#F5A623"
                            Stroke="Transparent"
                            Padding="6,2"
                            VerticalOptions="Center">
                        <Label x:Name="LblCount"
                               Text="0"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                    </Border>
                </HorizontalStackLayout>

                <Border StrokeShape="RoundRectangle 20"
                        BackgroundColor="{AppThemeBinding Light=#1A1A1A, Dark=#ECEFF1}"
                        Stroke="Transparent"
                        Padding="18,8"
                        VerticalOptions="Center">
                    <Label Text="dodaj konto"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=White, Dark=#1A1A1A}"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDodajKontoClicked"/>
                    </Border.GestureRecognizers>
                </Border>

                <BoxView Color="Transparent"
                         HorizontalOptions="FillAndExpand"
                         VerticalOptions="Center"/>

                <Border StrokeShape="RoundRectangle 20"
                        Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#444}"
                        BackgroundColor="Transparent"
                        Padding="14,8"
                        VerticalOptions="Center">
                    <Grid ColumnDefinitions="*,14">
                        <Label x:Name="LblTypFilter" Grid.Column="0"
                               Text="Wszystkie typy"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#555, Dark=#AAA}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="▾"
                               FontSize="11"
                               TextColor="{AppThemeBinding Light=#555, Dark=#AAA}"
                               VerticalOptions="Center"
                               Margin="6,0,0,0"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTypDropdownTapped"/>
                    </Border.GestureRecognizers>
                </Border>

            </HorizontalStackLayout>
        </ScrollView>

        <!-- Sekcja listy kont -->
        <Grid Grid.Row="2"
              RowDefinitions="Auto,Auto,*"
              BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1C}">

            <ScrollView Grid.Row="1"
                        x:Name="HeaderScroll"
                        Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never">
                <Grid ColumnDefinitions="180,120,*,130"
                      Padding="12,8">
                    <Label Grid.Column="0" Text="Nazwa"     Style="{StaticResource ColHeader}"/>
                    <Label Grid.Column="1" Text="Typ konta" Style="{StaticResource ColHeader}"/>
                    <Label Grid.Column="2" Text="Numer"     Style="{StaticResource ColHeader}"/>
                    <Label Grid.Column="3" Text="Użytkownik / Saldo" Style="{StaticResource ColHeader}"/>
                </Grid>
            </ScrollView>

            <BoxView Grid.Row="1"
                     VerticalOptions="End"
                     HeightRequest="1"
                     Color="{AppThemeBinding Light=#E0E0E0, Dark=#2A2A2A}"/>

            <CollectionView Grid.Row="2"
                            x:Name="KontaList"
                            BackgroundColor="Transparent"
                            VerticalScrollBarVisibility="Always">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid RowDefinitions="Auto,1">
                            <ScrollView Orientation="Horizontal"
                                        HorizontalScrollBarVisibility="Never"
                                        Scrolled="OnRowScrolled">
                                <Grid ColumnDefinitions="180,120,*,130"
                                      Padding="12,12"
                                      BackgroundColor="Transparent">
                                    <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                                        <Label Text="{Binding TypEmoji}" FontSize="18" VerticalOptions="Center"/>
                                        <Label Text="{Binding Nazwa}" Style="{StaticResource ColCell}"/>
                                    </HorizontalStackLayout>
                                    <Label Grid.Column="1" Text="{Binding Typ}"   Style="{StaticResource ColCell}"/>
                                    <Label Grid.Column="2" Text="{Binding Numer}" Style="{StaticResource ColCell}"/>
                                    <Label Grid.Column="3" Text="{Binding SaldoStr}"
                                           Style="{StaticResource ColCellBold}"
                                           TextColor="{Binding SaldoColor}"/>
                                </Grid>
                            </ScrollView>
                            <BoxView Grid.Row="1"
                                     Color="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A2A}"
                                     HeightRequest="1"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <Grid Padding="20">
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="⚠️" FontSize="18" VerticalOptions="Center"/>
                            <Label Text="Brak dostępnych danych"
                                   FontSize="15"
                                   TextColor="{AppThemeBinding Light=#555555, Dark=#90A4AE}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Grid>
                </CollectionView.EmptyView>
            </CollectionView>
        </Grid>

        <ctrl:DrawerMenu Grid.Row="0"
                         Grid.RowSpan="3"
                         x:Name="Drawer"
                         ZIndex="50"/>

    </Grid>

</ContentPage>
