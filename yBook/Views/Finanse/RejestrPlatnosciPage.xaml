<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ctrl="clr-namespace:yBook.Controls"
             x:Class="yBook.Views.Finanse.RejestrPlatnosciPage"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>

        <!-- Kolumny: szerokości dopasowane do ekranu -->
        <x:Double x:Key="ColW0">100</x:Double>
        <x:Double x:Key="ColW1">130</x:Double>
        <x:Double x:Key="ColW2">130</x:Double>
        <x:Double x:Key="ColW3">120</x:Double>
        <x:Double x:Key="ColW4">100</x:Double>
        <x:Double x:Key="ColW5">100</x:Double>
        <x:Double x:Key="ColW6">120</x:Double>
        <x:Double x:Key="ColW7">130</x:Double>

        <Style x:Key="ColHeader" TargetType="Label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#555555, Dark=#90A4AE}"/>
            <Setter Property="VerticalOptions" Value="Center"/>
            <Setter Property="LineBreakMode" Value="TailTruncation"/>
        </Style>

        <Style x:Key="ColCell" TargetType="Label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#1A1A1A, Dark=#ECEFF1}"/>
            <Setter Property="VerticalOptions" Value="Center"/>
            <Setter Property="LineBreakMode" Value="TailTruncation"/>
        </Style>

        <Style x:Key="ColCellBold" TargetType="Label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="VerticalOptions" Value="Center"/>
            <Setter Property="LineBreakMode" Value="TailTruncation"/>
        </Style>

        <!-- Pill filter button -->
        <Style x:Key="FilterPill" TargetType="Border">
            <Setter Property="StrokeShape" Value="RoundRectangle 20"/>
            <Setter Property="Stroke" Value="{AppThemeBinding Light=#CCCCCC, Dark=#444}"/>
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="VerticalOptions" Value="Center"/>
        </Style>

    </ContentPage.Resources>

    <Grid RowDefinitions="60,Auto,*"
          BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

        <!-- Nagłówek strony -->
        <ctrl:PageHeader Grid.Row="0"
                         Title="Rejestr płatności"
                         Icon="💳"
                         ShowBack="True"
                         x:Name="Header"/>

        <!-- Pasek filtrów — przewijalny poziomo na małych ekranach -->
        <ScrollView Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalScrollBarVisibility="Never"
                    VerticalScrollBarVisibility="Never">

            <HorizontalStackLayout Spacing="10"
                                   Padding="12,10"
                                   VerticalOptions="Center">

                <!-- Tytuł + licznik -->
                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                    <Label Text="Rejestr płatności"
                           FontSize="15"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#ECEFF1}"/>
                    <Border StrokeShape="RoundRectangle 10"
                            BackgroundColor="#F5A623"
                            Stroke="Transparent"
                            Padding="6,2"
                            VerticalOptions="Center">
                        <Label x:Name="LblCount"
                               Text="0"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                    </Border>
                </HorizontalStackLayout>

                <!-- Przycisk dodaj -->
                <Border StrokeShape="RoundRectangle 20"
                        BackgroundColor="{AppThemeBinding Light=#1A1A1A, Dark=#ECEFF1}"
                        Stroke="Transparent"
                        Padding="18,8"
                        VerticalOptions="Center">
                    <Label Text="dodaj"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=White, Dark=#1A1A1A}"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDodajClicked"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Filtr konta (dropdown) -->
                <Border Style="{StaticResource FilterPill}">
                    <Grid ColumnDefinitions="*,18" MinimumWidthRequest="110">
                        <Label x:Name="LblKontoFilter"
                               Grid.Column="0"
                               Text="Wybierz konto"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#555, Dark=#AAA}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="▾"
                               FontSize="11"
                               VerticalOptions="Center"
                               Margin="4,0,0,0"
                               TextColor="{AppThemeBinding Light=#555, Dark=#AAA}"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnKontoFilterTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Data od -->
                <Border Style="{StaticResource FilterPill}">
                    <Grid ColumnDefinitions="*,20" MinimumWidthRequest="95">
                        <Label x:Name="LblDataOd"
                               Grid.Column="0"
                               Text="Data od"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#555, Dark=#AAA}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="📅"
                               FontSize="13"
                               VerticalOptions="Center"
                               Margin="4,0,0,0"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDataOdTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Data do -->
                <Border Style="{StaticResource FilterPill}">
                    <Grid ColumnDefinitions="*,20" MinimumWidthRequest="90">
                        <Label x:Name="LblDataDo"
                               Grid.Column="0"
                               Text="Data do"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#555, Dark=#AAA}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="📅"
                               FontSize="13"
                               VerticalOptions="Center"
                               Margin="4,0,0,0"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDataDoTapped"/>
                    </Border.GestureRecognizers>
                </Border>

            </HorizontalStackLayout>
        </ScrollView>

        <!-- Tabela -->
        <Grid Grid.Row="2"
              RowDefinitions="Auto,1,*"
              BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1C}">

            <!-- Nagłówek kolumn -->
            <ScrollView Grid.Row="0"
                        x:Name="HeaderScroll"
                        Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never">
                <Grid ColumnDefinitions="100,130,130,120,100,100,120,130"
                      Padding="12,8">
                    <Label Grid.Column="0" Text="Data"             Style="{StaticResource ColHeader}"/>
                    <Label Grid.Column="1" Text="Numer rezerwacji" Style="{StaticResource ColHeader}"/>
                    <Label Grid.Column="2" Text="Klient"           Style="{StaticResource ColHeader}"/>
                    <Label Grid.Column="3" Text="Typ transakcji"   Style="{StaticResource ColHeader}"/>
                    <Label Grid.Column="4" Text="Przychód"         Style="{StaticResource ColHeader}"/>
                    <Label Grid.Column="5" Text="Rozchód"          Style="{StaticResource ColHeader}"/>
                    <Label Grid.Column="6" Text="Opis"             Style="{StaticResource ColHeader}"/>
                    <Label Grid.Column="7" Text="Balans"           Style="{StaticResource ColHeader}"/>
                </Grid>
            </ScrollView>

            <!-- Separator -->
            <BoxView Grid.Row="1"
                     HeightRequest="1"
                     Color="{AppThemeBinding Light=#E0E0E0, Dark=#2A2A2A}"/>

            <!-- Lista wierszy -->
            <CollectionView Grid.Row="2"
                            x:Name="PlatnosciList"
                            BackgroundColor="Transparent"
                            VerticalScrollBarVisibility="Always"
                            SelectionMode="Single"
                            SelectionChanged="OnItemSelected">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid RowDefinitions="Auto,1">
                            <ScrollView Orientation="Horizontal"
                                        HorizontalScrollBarVisibility="Never"
                                        Scrolled="OnRowScrolled">
                                <Grid ColumnDefinitions="100,130,130,120,100,100,120,130"
                                      Padding="12,12"
                                      BackgroundColor="Transparent">

                                    <Label Grid.Column="0"
                                           Text="{Binding DataStr}"
                                           Style="{StaticResource ColCell}"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding NumerRezerwacji}"
                                           Style="{StaticResource ColCell}"/>
                                    <Label Grid.Column="2"
                                           Text="{Binding Klient}"
                                           Style="{StaticResource ColCell}"/>
                                    <HorizontalStackLayout Grid.Column="3"
                                                           Spacing="5"
                                                           VerticalOptions="Center">
                                        <Label Text="{Binding TypEmoji}"
                                               FontSize="14"
                                               VerticalOptions="Center"/>
                                        <Label Text="{Binding Typ}"
                                               Style="{StaticResource ColCell}"/>
                                    </HorizontalStackLayout>
                                    <Label Grid.Column="4"
                                           Text="{Binding PrzychodStr}"
                                           Style="{StaticResource ColCellBold}"
                                           TextColor="#43A047"/>
                                    <Label Grid.Column="5"
                                           Text="{Binding RozchodStr}"
                                           Style="{StaticResource ColCellBold}"
                                           TextColor="#E53935"/>
                                    <Label Grid.Column="6"
                                           Text="{Binding Tytul}"
                                           Style="{StaticResource ColCell}"/>
                                    <Label Grid.Column="7"
                                           Text="{Binding KwotaStr}"
                                           Style="{StaticResource ColCellBold}"
                                           TextColor="{Binding KwotaColor}"/>

                                </Grid>
                            </ScrollView>
                            <BoxView Grid.Row="1"
                                     HeightRequest="1"
                                     Color="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A2A}"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <!-- Stan pusty -->
                <CollectionView.EmptyView>
                    <Grid Padding="20">
                        <HorizontalStackLayout Spacing="10"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center">
                            <Label Text="⚠️" FontSize="18" VerticalOptions="Center"/>
                            <Label Text="Brak dostępnych danych"
                                   FontSize="15"
                                   TextColor="{AppThemeBinding Light=#555555, Dark=#90A4AE}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Grid>
                </CollectionView.EmptyView>

            </CollectionView>

            <!-- Loader -->
            <ActivityIndicator x:Name="Loader"
                               Grid.Row="2"
                               IsRunning="False"
                               IsVisible="False"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Color="#F5A623"/>

        </Grid>

        <!-- Drawer menu -->
        <ctrl:DrawerMenu Grid.Row="0"
                         Grid.RowSpan="3"
                         x:Name="Drawer"
                         ZIndex="50"/>

    </Grid>

</ContentPage>
