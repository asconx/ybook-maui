<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ctrl="clr-namespace:yBook.Controls"
             x:Class="yBook.Views.Ustawienia.PokojePage"
             BackgroundColor="White"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="60, Auto, *">

        <ctrl:PageHeader Grid.Row="0"
                         Title="Kwatery"
                         Icon="🏠"
                         ShowBack="True"/>

        <Grid Grid.Row="1" ColumnDefinitions="Auto, *" Padding="20,10" ColumnSpacing="15">
            <Button x:Name="AddRoomButton" Grid.Column="0"
                    Text="dodaj kwaterę" 
                    BackgroundColor="#212121" 
                    TextColor="White" 
                    CornerRadius="20" 
                    Padding="15,0"
                    HeightRequest="40"
                    FontSize="13"
                    FontAttributes="Bold"
                    Clicked="OnAddRoomClicked"/>

            <Border Grid.Column="1" 
                    Padding="15,0" 
                    StrokeShape="RoundRectangle 20" 
                    Stroke="#E0E0E0" 
                    HeightRequest="40" 
                    HorizontalOptions="Start"
                    WidthRequest="300">
                <Grid ColumnDefinitions="Auto, *">
                    <Label Text="🔍" VerticalOptions="Center" Margin="0,0,10,0"/>
                    <Entry Grid.Column="1" Placeholder="Szukaj" VerticalOptions="Center" FontSize="13"/>
                </Grid>
            </Border>
        </Grid>

        <ScrollView Grid.Row="2" Orientation="Both">
            <VerticalStackLayout>

                <Grid ColumnDefinitions="90, 100, 250, 100, 60, 140, 80, 300, 400" 
                      BackgroundColor="#FAFAFA" 
                      Padding="15,12">
                    <Label Grid.Column="1" Text="Zdjęcie" FontSize="12" TextColor="#888"/>
                    <Label Grid.Column="2" Text="Nazwa" FontSize="12" TextColor="#888"/>
                    <Label Grid.Column="3" Text="Skrócona nazwa" FontSize="12" TextColor="#888"/>
                    <Label Grid.Column="4" Text="Kolor" FontSize="12" TextColor="#888" HorizontalOptions="Center"/>
                    <Label Grid.Column="5" Text="Cena podstawowa" FontSize="12" TextColor="#888"/>
                    <Label Grid.Column="6" Text="Metraż" FontSize="12" TextColor="#888"/>
                    <Label Grid.Column="7" Text="Łóżka" FontSize="12" TextColor="#888"/>
                    <Label Grid.Column="8" Text="Udogodnienia" FontSize="12" TextColor="#888"/>
                </Grid>
                <RefreshView x:Name="RefreshControl" Refreshing="OnRefreshRequested">
                     <CollectionView x:Name="PokojList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="90, 100, 250, 100, 60, 140, 80, 300, 400" 
                                  Padding="15,10" 
                                  VerticalOptions="Center">

                                <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                                    <Border StrokeShape="RoundRectangle 15" HeightRequest="30" WidthRequest="30" BackgroundColor="#76B5C5" StrokeThickness="0">
                                        <Label Text="✎" TextColor="White" VerticalOptions="Center" HorizontalOptions="Center" FontSize="14" Margin="0,0,1,1"/>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnZmienSzczegolyTapped"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <Border StrokeShape="RoundRectangle 15" HeightRequest="30" WidthRequest="30" BackgroundColor="#E59866" StrokeThickness="0">
                                        <Label Text="🗑" TextColor="White" VerticalOptions="Center" HorizontalOptions="Center" FontSize="14"/>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnDeleteTapped"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                </HorizontalStackLayout>

                                <Border Grid.Column="1" StrokeShape="RoundRectangle 4" HeightRequest="55" WidthRequest="85" StrokeThickness="0">
                                    <Image Source="{Binding ImageUrl}" Aspect="AspectFill"/>
                                </Border>

                                <Label Grid.Column="2" Text="{Binding NazwaText}" VerticalOptions="Center" FontAttributes="Bold" FontSize="13" TextColor="#222222"/>
                                <Label Grid.Column="3" Text="{Binding ShortNameText}" VerticalOptions="Center" HorizontalOptions="Start" FontSize="13" TextColor="#222222"/>
                                <HorizontalStackLayout Grid.Column="4" Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Border StrokeShape="RoundRectangle 10"
                                            HeightRequest="16" WidthRequest="16"
                                            Stroke="#DDDDDD" StrokeThickness="1"
                                            BackgroundColor="{Binding ColorValue}" />
                                    <Label Text="{Binding ColorText}" FontSize="12" TextColor="#222222" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                                <Label Grid.Column="5" Text="{Binding DefaultPrice}" VerticalOptions="Center" HorizontalOptions="Start" FontSize="13" TextColor="#222222"/>
                                <Label Grid.Column="6" Text="{Binding AreaText}" VerticalOptions="Center" FontSize="13" TextColor="#222222"/>

                                <HorizontalStackLayout Grid.Column="7" Spacing="5" VerticalOptions="Center"
                                                       BindableLayout.ItemsSource="{Binding BedItems}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Border StrokeShape="RoundRectangle 12" Stroke="#76B5C5" Padding="10,2" BackgroundColor="Transparent">
                                                <Label Text="{Binding .}" FontSize="11" TextColor="#76B5C5"/>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </HorizontalStackLayout>

                                <FlexLayout Grid.Column="8" Wrap="Wrap" AlignItems="Center"
                                            BindableLayout.ItemsSource="{Binding AmenityItems}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <HorizontalStackLayout Spacing="4" Margin="6,0,0,0">
                                                <Label Text="✓" TextColor="#4CAF50" FontAttributes="Bold" FontSize="12"/>
                                                <Label Text="{Binding .}" FontSize="12"/>
                                            </HorizontalStackLayout>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </FlexLayout>

                                <BoxView Grid.ColumnSpan="9" HeightRequest="1" Color="#F0F0F0" VerticalOptions="End"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                    
                    
                </RefreshView>
               

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>