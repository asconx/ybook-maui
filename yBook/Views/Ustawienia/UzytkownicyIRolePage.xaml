<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="yBook.Views.Uzytkownicy.UzytkownicyIRolePage"
             Title="Użytkownicy i role"
             BackgroundColor="#F5F5F5">

    <VerticalStackLayout Spacing="0">

        <Grid ColumnDefinitions="Auto, Auto" Padding="20,15" BackgroundColor="White">
            <Button x:Name="BtnUsersTab"
                    Grid.Column="0"
                    Text="Użytkownicy"
                    BackgroundColor="#E0E0E0"
                    TextColor="#333"
                    Margin="0,0 autor,10,0"
                    Clicked="OnUsersTabClicked" />
            <Button x:Name="BtnRolesTab"
                    Grid.Column="1"
                    Text="Role"
                    BackgroundColor="#1565C0"
                    TextColor="White"
                    Clicked="OnRolesTabClicked" />
        </Grid>

        <Button Text="+ Dodaj nową rolę"
                BackgroundColor="#1565C0"
                TextColor="White"
                FontAttributes="Bold"
                Margin="20,10"
                HeightRequest="45"
                Clicked="OnAddRoleClicked" />

        <Grid RowDefinitions="Auto, *" Margin="20,0,20,20" HeightRequest="600">

            <Grid Grid.Row="0" ColumnDefinitions="120, 180, *" BackgroundColor="#1565C0" Padding="15,10">
                <Label Grid.Column="0" Text="Akcje" TextColor="White" FontAttributes="Bold"/>
                <Label Grid.Column="1" Text="Nazwa roli" TextColor="White" FontAttributes="Bold"/>
                <Label Grid.Column="2" Text="Uprawnienia" TextColor="White" FontAttributes="Bold"/>
            </Grid>

            <CollectionView Grid.Row="1" x:Name="RolesCollection" BackgroundColor="White">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="120, 180, *" Padding="10" BackgroundColor="White">
                            <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                                <Button Text="✎" WidthRequest="45" Clicked="OnEditRoleClicked" BackgroundColor="White" BorderColor="#1565C0" BorderWidth="1" TextColor="#1565C0"/>
                                <Button Text="🗑" WidthRequest="45" Clicked="OnDeleteRoleClicked" BackgroundColor="White" BorderColor="Red" BorderWidth="1" TextColor="Red"/>
                            </HorizontalStackLayout>

                            <Label Grid.Column="1" Text="{Binding Name}" VerticalOptions="Center" FontAttributes="Bold" TextColor="Black"/>

                            <Frame Grid.Column="2" Padding="5" Margin="5" HasShadow="False" BorderColor="#EEE" BackgroundColor="#FAFAFA">
                                <Label Text="{Binding PermissionsDisplay}" FontSize="11" TextColor="#444" LineBreakMode="WordWrap"/>
                            </Frame>

                            <BoxView Grid.ColumnSpan="3" HeightRequest="1" BackgroundColor="#F0F0F0" VerticalOptions="End"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Label Text="Ładowanie danych lub brak ról..." HorizontalOptions="Center" Margin="0,50,0,0"/>
                </CollectionView.EmptyView>
            </CollectionView>
        </Grid>
    </VerticalStackLayout>
</ContentPage>