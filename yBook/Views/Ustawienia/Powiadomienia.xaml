<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="yBook.Views.Ustawienia.PowiadomieniaPage"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="60,*">

        <!-- HEADER -->
        <Grid BackgroundColor="#F5F5F5" Padding="16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <HorizontalStackLayout VerticalOptions="Center" Spacing="8">
                <Label Text="Powiadomienia" FontSize="18" FontAttributes="Bold"/>
                <Frame BackgroundColor="#FFB74D"
                       Padding="6,2"
                       CornerRadius="10"
                       HasShadow="False">
                    <Label Text="5" FontSize="12"/>
                </Frame>
            </HorizontalStackLayout>

            <Button Grid.Column="1"
                    Text="dodaj"
                    BackgroundColor="Black"
                    TextColor="White"
                    CornerRadius="20"
                    HeightRequest="36"
                    Padding="16,0"/>
        </Grid>

        <!-- LISTA -->
        <CollectionView Grid.Row="1"
                        x:Name="ListaPowiadomien"
                        Margin="0,10">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="12"
                           Margin="10,5"
                           BorderColor="#E0E0E0"
                           CornerRadius="8">

                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                            <!-- IKONY -->
                            <HorizontalStackLayout Spacing="8">
                                <Frame BackgroundColor="#80CBC4"
                                       Padding="8"
                                       CornerRadius="20"
                                       HasShadow="False">
                                    <Label Text="✏️"/>
                                </Frame>

                                <Frame BackgroundColor="#FFCC80"
                                       Padding="8"
                                       CornerRadius="20"
                                       HasShadow="False">
                                    <Label Text="🗑"/>
                                </Frame>
                            </HorizontalStackLayout>

                            <!-- NAZWA + OPIS -->
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="{Binding Nazwa}"
                                       FontAttributes="Bold"
                                       FontSize="14"/>

                                <Label Text="{Binding Typ}"
                                       FontSize="13"/>

                                <Label Text="{Binding Opis}"
                                       FontSize="12"
                                       TextColor="#777"/>
                            </VerticalStackLayout>

                            <!-- PRAWA STRONA -->
                            <VerticalStackLayout Grid.Column="2"
                                                 Spacing="6"
                                                 HorizontalOptions="End">

                                <Button Text="Powiadomienie mailowe"
                                        FontSize="11"
                                        CornerRadius="20"
                                        Padding="10,4"
                                        BorderColor="#4FC3F7"
                                        BorderWidth="1"
                                        BackgroundColor="Transparent"
                                        TextColor="#4FC3F7"/>

                                <Button Text="Powiadomienie SMS"
                                        FontSize="11"
                                        CornerRadius="20"
                                        Padding="10,4"
                                        BorderColor="#4FC3F7"
                                        BorderWidth="1"
                                        BackgroundColor="Transparent"
                                        TextColor="#4FC3F7"/>
                            </VerticalStackLayout>

                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>