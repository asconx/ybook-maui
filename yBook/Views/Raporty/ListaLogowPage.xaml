<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ctrl="clr-namespace:yBook.Controls"
             x:Class="yBook.Views.Raporty.ListaLogowPage"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <Style x:Key="ColHeader" TargetType="Label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#555555, Dark=#90A4AE}"/>
            <Setter Property="VerticalOptions" Value="Center"/>
            <Setter Property="LineBreakMode" Value="TailTruncation"/>
        </Style>
        <Style x:Key="ColCell" TargetType="Label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#1A1A1A, Dark=#ECEFF1}"/>
            <Setter Property="VerticalOptions" Value="Center"/>
            <Setter Property="LineBreakMode" Value="TailTruncation"/>
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="60, Auto, *"
          BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

        <!-- Nagłówek z hamburgerem -->
        <ctrl:PageHeader Grid.Row="0"
                         Title="Lista logów"
                         Icon="📜"
                         ShowBack="True"
                         x:Name="Header"/>

        <!-- Pasek filtrów -->
        <ScrollView Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalScrollBarVisibility="Never"
                    VerticalScrollBarVisibility="Never">
            <HorizontalStackLayout Spacing="8" Padding="12,10" VerticalOptions="Center">

                <!-- Tytuł + licznik -->
                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                    <Label Text="Rejestr akcji"
                           FontSize="15"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#ECEFF1}"/>
                    <Border StrokeShape="RoundRectangle 10"
                            BackgroundColor="#607D8B"
                            Stroke="Transparent"
                            Padding="6,2"
                            VerticalOptions="Center">
                        <Label x:Name="LblCount"
                               Text="0"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="White"/>
                    </Border>
                </HorizontalStackLayout>

                <BoxView WidthRequest="1" HeightRequest="20" Color="#CCCCCC" VerticalOptions="Center"/>

                <!-- Filtr: Data od -->
                <Border StrokeShape="RoundRectangle 8"
                        Stroke="#CCCCCC"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}"
                        Padding="10,6">
                    <Label x:Name="LblDataOd"
                           Text="Data od"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#555, Dark=#90A4AE}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDataOdTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Border>

                <!-- Filtr: Data do -->
                <Border StrokeShape="RoundRectangle 8"
                        Stroke="#CCCCCC"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}"
                        Padding="10,6">
                    <Label x:Name="LblDataDo"
                           Text="Data do"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#555, Dark=#90A4AE}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDataDoTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Border>

                <!-- Filtr: Użytkownik -->
                <Border StrokeShape="RoundRectangle 8"
                        Stroke="#CCCCCC"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}"
                        Padding="10,6">
                    <Label x:Name="LblFiltrUzytkownik"
                           Text="Użytkownik"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#555, Dark=#90A4AE}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFiltrUzytkownikTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Border>

                <!-- Filtr: Typ akcji -->
                <Border StrokeShape="RoundRectangle 8"
                        Stroke="#CCCCCC"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}"
                        Padding="10,6">
                    <Label x:Name="LblFiltrTyp"
                           Text="Typ akcji"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#555, Dark=#90A4AE}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFiltrTypTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Border>

                <!-- Reset filtrów -->
                <Border StrokeShape="RoundRectangle 8"
                        Stroke="#EF5350"
                        BackgroundColor="Transparent"
                        Padding="10,6">
                    <Label Text="✕ Wyczyść"
                           FontSize="13"
                           TextColor="#EF5350">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnResetFiltrów"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Border>

            </HorizontalStackLayout>
        </ScrollView>

        <!-- Tabela -->
        <Grid Grid.Row="2" RowDefinitions="Auto, *">

            <!-- Nagłówek tabeli -->
            <ScrollView Grid.Row="0"
                        x:Name="HeaderScroll"
                        Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never"
                        VerticalScrollBarVisibility="Never">
                <Grid x:Name="TableHeader"
                      BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#1E1E2E}"
                      Padding="12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Text="Data i godzina"   Style="{StaticResource ColHeader}"/>
                    <Label Grid.Column="1" Text="Użytkownik"       Style="{StaticResource ColHeader}"/>
                    <Label Grid.Column="2" Text="Typ akcji"        Style="{StaticResource ColHeader}"/>
                    <Label Grid.Column="3" Text="Opis"             Style="{StaticResource ColHeader}"/>
                    <Label Grid.Column="4" Text="Adres IP"         Style="{StaticResource ColHeader}"/>
                </Grid>
            </ScrollView>

            <!-- Lista wierszy -->
            <ScrollView Grid.Row="1"
                        x:Name="BodyScroll"
                        Orientation="Both"
                        HorizontalScrollBarVisibility="Never"
                        VerticalScrollBarVisibility="Default"
                        Scrolled="OnBodyScrolled">
                <CollectionView x:Name="LogiList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,9"
                                  BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A2E}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="300"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>

                                <!-- Data i godzina -->
                                <Label Grid.Column="0"
                                       Text="{Binding DataStr}"
                                       Style="{StaticResource ColCell}"
                                       FontSize="11"/>

                                <!-- Użytkownik -->
                                <Label Grid.Column="1"
                                       Text="{Binding Uzytkownik}"
                                       Style="{StaticResource ColCell}"
                                       FontAttributes="Bold"/>

                                <!-- Typ – kolorowy badge -->
                                <Border Grid.Column="2"
                                        StrokeShape="RoundRectangle 6"
                                        BackgroundColor="{Binding TypKolor}"
                                        Stroke="Transparent"
                                        Padding="6,2"
                                        HorizontalOptions="Start"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding TypLabel}"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="White"/>
                                </Border>

                                <!-- Opis -->
                                <Label Grid.Column="3"
                                       Text="{Binding Opis}"
                                       Style="{StaticResource ColCell}"/>

                                <!-- IP -->
                                <Label Grid.Column="4"
                                       Text="{Binding AdresIp}"
                                       Style="{StaticResource ColCell}"
                                       FontSize="11"
                                       TextColor="{AppThemeBinding Light=#888, Dark=#607D8B}"/>

                                <!-- separator -->
                                <BoxView Grid.ColumnSpan="5"
                                         HeightRequest="1"
                                         VerticalOptions="End"
                                         Color="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A3E}"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </ScrollView>

        </Grid>

        <!-- DrawerMenu -->
        <ctrl:DrawerMenu Grid.RowSpan="3" x:Name="Drawer"/>

    </Grid>
</ContentPage>