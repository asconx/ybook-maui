<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:yBook.Views.Surveys"
             x:Class="yBook.Views.Surveys.EditSurveyPage"
             x:DataType="vm:EditSurveyViewModel"
             Title="Edytuj ankietę"
             BackgroundColor="{AppThemeBinding Light=#F4F6F9, Dark=#121212}">

    <Grid RowDefinitions="*,Auto" Padding="16" RowSpacing="16">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="16">

                <!-- Loading -->
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="#1565C0"/>

                <!-- Błąd -->
                <Border IsVisible="{Binding HasError}"
                        BackgroundColor="#FFEBEE"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0"
                        Padding="12">
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#C62828"
                           FontSize="12"/>
                </Border>

                <!-- Tytuł -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Tytuł ankiety *"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#263238, Dark=#ECEFF1}"/>
                    <Border StrokeShape="RoundRectangle 8"
                            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444}"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2C2C2C}"
                            Padding="12,0"
                            HeightRequest="48">
                        <Entry Placeholder="Wpisz tytuł ankiety"
                               Text="{Binding Title}"
                               TextColor="{AppThemeBinding Light=#263238, Dark=#ECEFF1}"
                               PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#616161}"
                               BackgroundColor="Transparent"
                               FontSize="14"
                               VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Opis -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Opis ankiety"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#263238, Dark=#ECEFF1}"/>
                    <Border StrokeShape="RoundRectangle 8"
                            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444}"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2C2C2C}"
                            Padding="12,8">
                        <Editor Placeholder="Wpisz opis ankiety (opcjonalnie)"
                                Text="{Binding Description}"
                                TextColor="{AppThemeBinding Light=#263238, Dark=#ECEFF1}"
                                PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#616161}"
                                BackgroundColor="Transparent"
                                HeightRequest="120"
                                FontSize="14"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Info -->
                <Border BackgroundColor="#E3F2FD"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0"
                        Padding="12">
                    <Label Text="Pola oznaczone * są wymagane"
                           FontSize="12"
                           TextColor="#1565C0"/>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Przyciski -->
        <Grid Grid.Row="1" ColumnDefinitions="*,8,*">
            <Button Grid.Column="0"
                    Text="Anuluj"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="#E0E0E0"
                    TextColor="#424242"
                    Padding="12"
                    CornerRadius="8"
                    FontSize="14"
                    FontAttributes="Bold"/>
            <Button Grid.Column="2"
                    Text="Zapisz ankietę"
                    Command="{Binding SaveSurveyCommand}"
                    BackgroundColor="#1565C0"
                    TextColor="White"
                    Padding="12"
                    CornerRadius="8"
                    FontSize="14"
                    FontAttributes="Bold"/>
        </Grid>

    </Grid>

</ContentPage>
