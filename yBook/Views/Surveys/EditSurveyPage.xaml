<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="yBook.Views.Surveys.EditSurveyPage"
             Title="Edytuj ankietę"
             BackgroundColor="{AppThemeBinding Light=#F4F6F9, Dark=#121212}">

    <Grid RowDefinitions="*,Auto" Padding="16" RowSpacing="16">

        <!-- Formularz -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="16">

                <!-- Błąd -->
                <Frame x:Name="ErrorFrame"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyBoolConverter}}"
                       CornerRadius="10"
                       Padding="12"
                       BackgroundColor="#FFEBEE">
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#C62828"
                           FontSize="12"/>
                </Frame>

                <!-- Tytuł -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Tytuł ankiety *"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#263238, Dark=#ECEFF1}"/>
                    <Entry Placeholder="Wpisz tytuł ankiety"
                           Text="{Binding Title}"
                           BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2C2C2C}"
                           TextColor="{AppThemeBinding Light=#263238, Dark=#ECEFF1}"
                           PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#616161}"
                          
                           FontSize="14"/>
                </VerticalStackLayout>

                <!-- Opis -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Opis ankiety"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#263238, Dark=#ECEFF1}"/>
                    <Editor Placeholder="Wpisz opis ankiety (opcjonalnie)"
                            Text="{Binding Description}"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2C2C2C}"
                            TextColor="{AppThemeBinding Light=#263238, Dark=#ECEFF1}"
                            PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#616161}"
                            HeightRequest="120"
                            FontSize="14"/>
                </VerticalStackLayout>

                <!-- Info -->
                <Frame CornerRadius="10" Padding="12" BackgroundColor="#E3F2FD" HasShadow="False">
                    <Label Text="Pola oznaczone * są wymagane"
                           FontSize="12"
                           TextColor="#1565C0"/>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Przyciski akcji -->
        <Grid Grid.Row="1" ColumnDefinitions="*,8,*" ColumnSpacing="8">
            <Button Grid.Column="0"
                    Text="Anuluj"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="#E0E0E0"
                    TextColor="#424242"
                    Padding="12"
                    CornerRadius="8"
                    FontSize="14"
                    FontAttributes="Bold"/>
            <Button Grid.Column="2"
                    Text="Zapisz ankietę"
                    Command="{Binding SaveSurveyCommand}"
                    BackgroundColor="#1565C0"
                    TextColor="White"
                    Padding="12"
                    CornerRadius="8"
                    FontSize="14"
                    FontAttributes="Bold"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"/>
        </Grid>

    </Grid>

</ContentPage>
