<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="yBook.Controls.PageHeader">

    <Grid HeightRequest="60"
          BackgroundColor="#1565C0"
          x:Name="RootGrid">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="44"/>
            <ColumnDefinition Width="44"/>
            <ColumnDefinition Width="8"/>
        </Grid.ColumnDefinitions>

        <!-- Hamburger LUB strzałka wstecz (zależnie od ShowBack) -->
        <ImageButton Grid.Column="0"
                     x:Name="LeftBtn"
                     BackgroundColor="Transparent"
                     Padding="14"
                     Clicked="OnLeftBtnClicked"
                     HorizontalOptions="Center"
                     VerticalOptions="Center">
            <ImageButton.Source>
                <FontImageSource x:Name="LeftBtnIcon"
                                 FontFamily="OpenSansRegular"
                                 Glyph="&#9776;"
                                 Color="White"
                                 Size="21"/>
            </ImageButton.Source>
        </ImageButton>

        <!-- Tytuł strony -->
        <StackLayout Grid.Column="1"
                     Orientation="Horizontal"
                     Spacing="8"
                     HorizontalOptions="Start"
                     VerticalOptions="Center">
            <Label x:Name="LblIcon" Text="🏨" FontSize="19" VerticalOptions="Center"/>
            <Label x:Name="LblTitle"
                   Text="yBook"
                   TextColor="White"
                   FontSize="18"
                   FontAttributes="Bold"
                   VerticalOptions="Center"/>
        </StackLayout>

        <!-- Powiadomienia -->
        <ImageButton Grid.Column="2"
                     x:Name="BtnNotify"
                     BackgroundColor="Transparent"
                     Padding="8"
                     HorizontalOptions="Center"
                     VerticalOptions="Center">
            <ImageButton.Source>
                <FontImageSource FontFamily="OpenSansRegular"
                                 Glyph="&#128276;"
                                 Color="White"
                                 Size="18"/>
            </ImageButton.Source>
        </ImageButton>

        <!-- Profil -->
        <ImageButton Grid.Column="3"
                     BackgroundColor="Transparent"
                     Padding="8"
                     HorizontalOptions="Center"
                     VerticalOptions="Center">
            <ImageButton.Source>
                <FontImageSource FontFamily="OpenSansRegular"
                                 Glyph="&#128100;"
                                 Color="White"
                                 Size="18"/>
            </ImageButton.Source>
        </ImageButton>

    </Grid>

</ContentView>
