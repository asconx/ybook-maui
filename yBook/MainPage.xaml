<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ctrl="clr-namespace:yBook.Controls"
             x:Class="yBook.MainPage"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="60,*">

        <!-- ── Stały header (komponent) ── -->
        <ctrl:PageHeader Grid.Row="0"
                         x:Name="Header"
                         Title="yBook"
                         Icon="🏨"
                         ShowBack="False"/>

        <!-- ── Treść główna — Pulpit ── -->
        <ScrollView Grid.Row="1"
                    BackgroundColor="{AppThemeBinding Light=#F4F6F9, Dark=#121212}">
            <VerticalStackLayout Padding="16" Spacing="16">

                <!-- Powitanie -->
                <VerticalStackLayout Spacing="2">
                    <Label x:Name="LblGreeting"
                           Text="Dzień dobry! 👋"
                           FontSize="22" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#1A237E, Dark=#90CAF9}"/>
                    <Label x:Name="LblDate"
                           Text=""
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#607D8B, Dark=#90A4AE}"/>
                </VerticalStackLayout>

                <!-- Karty statystyk (2×2) -->
                <Grid ColumnDefinitions="*,12,*" RowDefinitions="Auto,12,Auto">

                    <Frame Grid.Row="0" Grid.Column="0"
                           CornerRadius="14" Padding="14" HasShadow="True"
                           BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="🛬  Przyjazdy" FontSize="12"
                                   TextColor="{AppThemeBinding Light=#607D8B, Dark=#90A4AE}"/>
                            <Label x:Name="LblArrivals" Text="–"
                                   FontSize="30" FontAttributes="Bold" TextColor="#1565C0"/>
                            <Label Text="dziś" FontSize="11"
                                   TextColor="{AppThemeBinding Light=#9E9E9E, Dark=#616161}"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="0" Grid.Column="2"
                           CornerRadius="14" Padding="14" HasShadow="True"
                           BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="🛫  Wyjazdy" FontSize="12"
                                   TextColor="{AppThemeBinding Light=#607D8B, Dark=#90A4AE}"/>
                            <Label x:Name="LblDepartures" Text="–"
                                   FontSize="30" FontAttributes="Bold" TextColor="#E53935"/>
                            <Label Text="dziś" FontSize="11"
                                   TextColor="{AppThemeBinding Light=#9E9E9E, Dark=#616161}"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="2" Grid.Column="0"
                           CornerRadius="14" Padding="14" HasShadow="True"
                           BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="🛏️  Zajętość" FontSize="12"
                                   TextColor="{AppThemeBinding Light=#607D8B, Dark=#90A4AE}"/>
                            <Label x:Name="LblOccupancy" Text="–"
                                   FontSize="30" FontAttributes="Bold" TextColor="#43A047"/>
                            <Label Text="pokoi zajętych" FontSize="11"
                                   TextColor="{AppThemeBinding Light=#9E9E9E, Dark=#616161}"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="2" Grid.Column="2"
                           CornerRadius="14" Padding="14" HasShadow="True"
                           BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="💰  Przychód" FontSize="12"
                                   TextColor="{AppThemeBinding Light=#607D8B, Dark=#90A4AE}"/>
                            <Label x:Name="LblRevenue" Text="–"
                                   FontSize="26" FontAttributes="Bold" TextColor="#6A1B9A"/>
                            <Label Text="dziś (PLN)" FontSize="11"
                                   TextColor="{AppThemeBinding Light=#9E9E9E, Dark=#616161}"/>
                        </VerticalStackLayout>
                    </Frame>

                </Grid>

                <!-- Szybkie akcje -->
                <Frame CornerRadius="14" Padding="16" HasShadow="True"
                       BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Szybkie akcje"
                               FontSize="14" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#37474F, Dark=#ECEFF1}"/>
                        <Grid ColumnDefinitions="*,8,*,8,*" HeightRequest="72">

                            <Frame Grid.Column="0" CornerRadius="10" Padding="0"
                                   BackgroundColor="#E3F2FD" HasShadow="False">
                                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
                                    <Label Text="📋" FontSize="22" HorizontalOptions="Center"/>
                                    <Label Text="Recepcja" FontSize="10" HorizontalOptions="Center"
                                           TextColor="#1565C0" FontAttributes="Bold"/>
                                </VerticalStackLayout>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnQuickAction" CommandParameter="Recepcja"/>
                                </Frame.GestureRecognizers>
                            </Frame>

                            <Frame Grid.Column="2" CornerRadius="10" Padding="0"
                                   BackgroundColor="#E8F5E9" HasShadow="False">
                                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
                                    <Label Text="📅" FontSize="22" HorizontalOptions="Center"/>
                                    <Label Text="Terminarz" FontSize="10" HorizontalOptions="Center"
                                           TextColor="#2E7D32" FontAttributes="Bold"/>
                                </VerticalStackLayout>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnQuickAction" CommandParameter="Terminarz"/>
                                </Frame.GestureRecognizers>
                            </Frame>

                            <Frame Grid.Column="4" CornerRadius="10" Padding="0"
                                   BackgroundColor="#F3E5F5" HasShadow="False">
                                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
                                    <Label Text="💳" FontSize="22" HorizontalOptions="Center"/>
                                    <Label Text="Płatności" FontSize="10" HorizontalOptions="Center"
                                           TextColor="#6A1B9A" FontAttributes="Bold"/>
                                </VerticalStackLayout>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnQuickAction" CommandParameter="RejestrPlatnosci"/>
                                </Frame.GestureRecognizers>
                            </Frame>

                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- Nadchodzące rezerwacje -->
                <Frame CornerRadius="14" Padding="16" HasShadow="True"
                       BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Nadchodzące rezerwacje"
                               FontSize="14" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#37474F, Dark=#ECEFF1}"/>

                        <BoxView HeightRequest="1" BackgroundColor="#ECEFF1"/>

                        <Grid ColumnDefinitions="36,*,Auto">
                            <Label Grid.Column="0" Text="🟢" FontSize="16" VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="1">
                                <Label Text="Jan Kowalski — pokój 101"
                                       FontSize="14"
                                       TextColor="{AppThemeBinding Light=#263238, Dark=#ECEFF1}"/>
                                <Label Text="Check-in: dziś · 2 noce"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light=#78909C, Dark=#90A4AE}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="480 zł"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="#1565C0" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#ECEFF1"/>

                        <Grid ColumnDefinitions="36,*,Auto">
                            <Label Grid.Column="0" Text="🟡" FontSize="16" VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="1">
                                <Label Text="Anna Nowak — apartament A"
                                       FontSize="14"
                                       TextColor="{AppThemeBinding Light=#263238, Dark=#ECEFF1}"/>
                                <Label Text="Check-in: jutro · 3 noce"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light=#78909C, Dark=#90A4AE}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="1 050 zł"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="#1565C0" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#ECEFF1"/>

                        <Label Text="Zobacz wszystkie rezerwacje →"
                               FontSize="13" TextColor="#1565C0" HorizontalOptions="End">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnQuickAction" CommandParameter="Rezerwacje"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </VerticalStackLayout>
                </Frame>

                <!-- Powiadomienie iCal -->
                <Frame CornerRadius="14" Padding="14" HasShadow="False"
                       BackgroundColor="#E3F2FD">
                    <Grid ColumnDefinitions="32,*">
                        <Label Grid.Column="0" Text="ℹ️" FontSize="18" VerticalOptions="Start"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Synchronizacja iCal aktywna"
                                   FontSize="13" FontAttributes="Bold" TextColor="#1565C0"/>
                            <Label Text="Ostatnia synchronizacja: dziś o 08:12"
                                   FontSize="12" TextColor="#1976D2"/>
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <Label Text="yBook v2.0 · ybook.pl"
                       FontSize="11" HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light=#B0BEC5, Dark=#455A64}"
                       Margin="0,4,0,16"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── DrawerMenu (komponent) ── -->
        <ctrl:DrawerMenu Grid.Row="0" Grid.RowSpan="2"
                         x:Name="Drawer"
                         ZIndex="50"/>

    </Grid>
</ContentPage>
