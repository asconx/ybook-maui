<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="yBook.MainPage"
             NavigationPage.HasNavigationBar="False">

    <!-- Root grid: stały layout strony -->
    <Grid RowDefinitions="60,*">

        <!-- ═══════════════════════════════════════════
             STAŁY HEADER (zawsze na górze)
        ═══════════════════════════════════════════ -->
        <Grid Grid.Row="0"
              BackgroundColor="{AppThemeBinding Light=#2C3E50, Dark=#1A252F}"
              Padding="0"
              ZIndex="10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>

            <!-- Hamburger Button -->
            <ImageButton Grid.Column="0"
                         x:Name="HamburgerBtn"
                         Clicked="OnHamburgerClicked"
                         BackgroundColor="Transparent"
                         Padding="16"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                <ImageButton.Source>
                    <FontImageSource FontFamily="OpenSansRegular"
                                     Glyph="&#9776;"
                                     Color="White"
                                     Size="22"/>
                </ImageButton.Source>
            </ImageButton>

            <!-- Tytuł aplikacji -->
            <Label Grid.Column="1"
                   Text="yBook"
                   TextColor="White"
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>

            <!-- Placeholder (np. ikona profilu) -->
            <ImageButton Grid.Column="2"
                         BackgroundColor="Transparent"
                         Padding="16"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                <ImageButton.Source>
                    <FontImageSource FontFamily="OpenSansRegular"
                                     Glyph="&#128100;"
                                     Color="White"
                                     Size="20"/>
                </ImageButton.Source>
            </ImageButton>

        </Grid>

        <!-- ═══════════════════════════════════════════
             TREŚĆ GŁÓWNA
        ═══════════════════════════════════════════ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24" Spacing="20">

                <Label Text="Witaj w yBook!"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#2C3E50, Dark=#ECF0F1}"/>

                <Label Text="Użyj przycisku ☰ aby otworzyć menu boczne."
                       FontSize="15"
                       TextColor="{AppThemeBinding Light=#7F8C8D, Dark=#BDC3C7}"/>

                <!-- Przykładowe karty z treścią -->
                <Frame CornerRadius="12" Padding="16" HasShadow="True"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#2C3E50}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="📖 Ostatnio czytane"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#2C3E50, Dark=White}"/>
                        <Label Text="Brak ostatnio czytanych książek."
                               FontSize="14"
                               TextColor="{AppThemeBinding Light=#95A5A6, Dark=#BDC3C7}"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame CornerRadius="12" Padding="16" HasShadow="True"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#2C3E50}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="⭐ Polecane"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#2C3E50, Dark=White}"/>
                        <Label Text="Odkryj nowe tytuły z naszej kolekcji."
                               FontSize="14"
                               TextColor="{AppThemeBinding Light=#95A5A6, Dark=#BDC3C7}"/>
                    </VerticalStackLayout>
                </Frame>

                <Button x:Name="CounterBtn"
                        Text="Kliknij mnie"
                        Clicked="OnCounterClicked"
                        BackgroundColor="#2C3E50"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="50"
                        FontAttributes="Bold"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ═══════════════════════════════════════════
             OVERLAY (przyciemnienie tła przy otwartym drawerze)
        ═══════════════════════════════════════════ -->
        <BoxView Grid.Row="0"
                 Grid.RowSpan="2"
                 x:Name="DrawerOverlay"
                 BackgroundColor="#80000000"
                 IsVisible="False"
                 ZIndex="20">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnOverlayTapped"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- ═══════════════════════════════════════════
             PANEL BOCZNY (Navigation Drawer)
        ═══════════════════════════════════════════ -->
        <Grid Grid.Row="0"
              Grid.RowSpan="2"
              x:Name="DrawerPanel"
              WidthRequest="280"
              HorizontalOptions="Start"
              TranslationX="-280"
              ZIndex="30"
              BackgroundColor="{AppThemeBinding Light=#2C3E50, Dark=#1A252F}">

            <VerticalStackLayout Spacing="0">

                <!-- Nagłówek drawera -->
                <Grid HeightRequest="160"
                      BackgroundColor="#1A252F"
                      Padding="20">
                    <VerticalStackLayout VerticalOptions="End" Spacing="4">
                        <Label Text="📚"
                               FontSize="40"
                               HorizontalOptions="Start"/>
                        <Label Text="yBook"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="White"/>
                        <Label Text="Twoja biblioteka"
                               FontSize="13"
                               TextColor="#BDC3C7"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- Separator -->
                <BoxView HeightRequest="1" BackgroundColor="#34495E"/>

                <!-- Menu items -->
                <VerticalStackLayout Spacing="0" Padding="0,8">

                    <Grid x:Name="MenuHome"
                          Padding="20,14"
                          BackgroundColor="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="🏠" FontSize="18" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Strona główna"
                               FontSize="15" TextColor="White" VerticalOptions="Center"/>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="Home"/>
                        </Grid.GestureRecognizers>
                    </Grid>

                    <Grid x:Name="MenuLibrary"
                          Padding="20,14"
                          BackgroundColor="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="📖" FontSize="18" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Moja biblioteka"
                               FontSize="15" TextColor="White" VerticalOptions="Center"/>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="Library"/>
                        </Grid.GestureRecognizers>
                    </Grid>

                    <Grid x:Name="MenuFavourites"
                          Padding="20,14"
                          BackgroundColor="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="⭐" FontSize="18" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Ulubione"
                               FontSize="15" TextColor="White" VerticalOptions="Center"/>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="Favourites"/>
                        </Grid.GestureRecognizers>
                    </Grid>

                    <Grid x:Name="MenuSearch"
                          Padding="20,14"
                          BackgroundColor="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="🔍" FontSize="18" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Szukaj"
                               FontSize="15" TextColor="White" VerticalOptions="Center"/>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="Search"/>
                        </Grid.GestureRecognizers>
                    </Grid>

                </VerticalStackLayout>

                <!-- Separator przed ustawieniami -->
                <BoxView HeightRequest="1" BackgroundColor="#34495E" Margin="0,8"/>

                <Grid Padding="20,14" BackgroundColor="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Text="⚙️" FontSize="18" VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="Ustawienia"
                           FontSize="15" TextColor="White" VerticalOptions="Center"/>
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="Settings"/>
                    </Grid.GestureRecognizers>
                </Grid>

            </VerticalStackLayout>

        </Grid>

    </Grid>

</ContentPage>
