<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="yBook.MainPage"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="60,*">

        <!-- ═══════════════════════════════════════════════════════════
             STAŁY HEADER
        ════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0"
              BackgroundColor="#1565C0"
              Padding="0"
              ZIndex="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="44"/>
                <ColumnDefinition Width="44"/>
                <ColumnDefinition Width="8"/>
            </Grid.ColumnDefinitions>

            <!-- Hamburger -->
            <ImageButton Grid.Column="0"
                         x:Name="HamburgerBtn"
                         Clicked="OnHamburgerClicked"
                         BackgroundColor="Transparent"
                         Padding="16"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                <ImageButton.Source>
                    <FontImageSource FontFamily="OpenSansRegular"
                                     Glyph="&#9776;"
                                     Color="White"
                                     Size="22"/>
                </ImageButton.Source>
            </ImageButton>

            <!-- Logo + nazwa -->
            <StackLayout Grid.Column="1"
                         Orientation="Horizontal"
                         Spacing="8"
                         HorizontalOptions="Start"
                         VerticalOptions="Center">
                <Label Text="🏨" FontSize="20" VerticalOptions="Center"/>
                <Label Text="yBook"
                       TextColor="White"
                       FontSize="20"
                       FontAttributes="Bold"
                       VerticalOptions="Center"/>
            </StackLayout>

            <!-- Powiadomienia -->
            <ImageButton Grid.Column="2"
                         BackgroundColor="Transparent"
                         Padding="8"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                <ImageButton.Source>
                    <FontImageSource FontFamily="OpenSansRegular"
                                     Glyph="&#128276;"
                                     Color="White"
                                     Size="19"/>
                </ImageButton.Source>
            </ImageButton>

            <!-- Profil -->
            <ImageButton Grid.Column="3"
                         BackgroundColor="Transparent"
                         Padding="8"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                <ImageButton.Source>
                    <FontImageSource FontFamily="OpenSansRegular"
                                     Glyph="&#128100;"
                                     Color="White"
                                     Size="19"/>
                </ImageButton.Source>
            </ImageButton>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             TREŚĆ GŁÓWNA — PULPIT
        ════════════════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="1"
                    BackgroundColor="{AppThemeBinding Light=#F4F6F9, Dark=#121212}">
            <VerticalStackLayout Padding="16" Spacing="16">

                <!-- Powitanie -->
                <VerticalStackLayout Spacing="2">
                    <Label x:Name="LblGreeting"
                           Text="Dzień dobry! 👋"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#1A237E, Dark=#90CAF9}"/>
                    <Label x:Name="LblDate"
                           Text=""
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#607D8B, Dark=#90A4AE}"/>
                </VerticalStackLayout>

                <!-- ── Karty statystyk (2×2) ── -->
                <Grid ColumnDefinitions="*,12,*"
                      RowDefinitions="Auto,12,Auto">

                    <Frame Grid.Row="0" Grid.Column="0"
                           CornerRadius="14" Padding="14" HasShadow="True"
                           BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="🛬  Przyjazdy"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#607D8B, Dark=#90A4AE}"/>
                            <Label x:Name="LblArrivals"
                                   Text="–"
                                   FontSize="30" FontAttributes="Bold"
                                   TextColor="#1565C0"/>
                            <Label Text="dziś" FontSize="11"
                                   TextColor="{AppThemeBinding Light=#9E9E9E, Dark=#616161}"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="0" Grid.Column="2"
                           CornerRadius="14" Padding="14" HasShadow="True"
                           BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="🛫  Wyjazdy"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#607D8B, Dark=#90A4AE}"/>
                            <Label x:Name="LblDepartures"
                                   Text="–"
                                   FontSize="30" FontAttributes="Bold"
                                   TextColor="#E53935"/>
                            <Label Text="dziś" FontSize="11"
                                   TextColor="{AppThemeBinding Light=#9E9E9E, Dark=#616161}"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="2" Grid.Column="0"
                           CornerRadius="14" Padding="14" HasShadow="True"
                           BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="🛏️  Zajętość"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#607D8B, Dark=#90A4AE}"/>
                            <Label x:Name="LblOccupancy"
                                   Text="–"
                                   FontSize="30" FontAttributes="Bold"
                                   TextColor="#43A047"/>
                            <Label Text="pokoi zajętych" FontSize="11"
                                   TextColor="{AppThemeBinding Light=#9E9E9E, Dark=#616161}"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="2" Grid.Column="2"
                           CornerRadius="14" Padding="14" HasShadow="True"
                           BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="💰  Przychód"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#607D8B, Dark=#90A4AE}"/>
                            <Label x:Name="LblRevenue"
                                   Text="–"
                                   FontSize="26" FontAttributes="Bold"
                                   TextColor="#6A1B9A"/>
                            <Label Text="dziś (PLN)" FontSize="11"
                                   TextColor="{AppThemeBinding Light=#9E9E9E, Dark=#616161}"/>
                        </VerticalStackLayout>
                    </Frame>

                </Grid>

                <!-- ── Szybkie akcje ── -->
                <Frame CornerRadius="14" Padding="16" HasShadow="True"
                       BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Szybkie akcje"
                               FontSize="14" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#37474F, Dark=#ECEFF1}"/>
                        <Grid ColumnDefinitions="*,8,*,8,*" HeightRequest="72">

                            <Frame Grid.Column="0" CornerRadius="10" Padding="0"
                                   BackgroundColor="#E3F2FD" HasShadow="False">
                                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
                                    <Label Text="📋" FontSize="22" HorizontalOptions="Center"/>
                                    <Label Text="Recepcja" FontSize="10" HorizontalOptions="Center"
                                           TextColor="#1565C0" FontAttributes="Bold"/>
                                </VerticalStackLayout>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="Recepcja"/>
                                </Frame.GestureRecognizers>
                            </Frame>

                            <Frame Grid.Column="2" CornerRadius="10" Padding="0"
                                   BackgroundColor="#E8F5E9" HasShadow="False">
                                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
                                    <Label Text="📅" FontSize="22" HorizontalOptions="Center"/>
                                    <Label Text="Terminarz" FontSize="10" HorizontalOptions="Center"
                                           TextColor="#2E7D32" FontAttributes="Bold"/>
                                </VerticalStackLayout>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="Terminarz"/>
                                </Frame.GestureRecognizers>
                            </Frame>

                            <Frame Grid.Column="4" CornerRadius="10" Padding="0"
                                   BackgroundColor="#F3E5F5" HasShadow="False">
                                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
                                    <Label Text="🗓️" FontSize="22" HorizontalOptions="Center"/>
                                    <Label Text="Kalendarz" FontSize="10" HorizontalOptions="Center"
                                           TextColor="#6A1B9A" FontAttributes="Bold"/>
                                </VerticalStackLayout>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="Kalendarz"/>
                                </Frame.GestureRecognizers>
                            </Frame>

                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- ── Nadchodzące rezerwacje ── -->
                <Frame CornerRadius="14" Padding="16" HasShadow="True"
                       BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Nadchodzące rezerwacje"
                               FontSize="14" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#37474F, Dark=#ECEFF1}"/>

                        <BoxView HeightRequest="1" BackgroundColor="#ECEFF1"/>

                        <Grid ColumnDefinitions="36,*,Auto">
                            <Label Grid.Column="0" Text="🟢" FontSize="16" VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="1">
                                <Label Text="Jan Kowalski — pokój 101"
                                       FontSize="14"
                                       TextColor="{AppThemeBinding Light=#263238, Dark=#ECEFF1}"/>
                                <Label Text="Check-in: dziś · 2 noce"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light=#78909C, Dark=#90A4AE}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="480 zł"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="#1565C0" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#ECEFF1"/>

                        <Grid ColumnDefinitions="36,*,Auto">
                            <Label Grid.Column="0" Text="🟡" FontSize="16" VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="1">
                                <Label Text="Anna Nowak — apartament A"
                                       FontSize="14"
                                       TextColor="{AppThemeBinding Light=#263238, Dark=#ECEFF1}"/>
                                <Label Text="Check-in: jutro · 3 noce"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light=#78909C, Dark=#90A4AE}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="1 050 zł"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="#1565C0" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#ECEFF1"/>

                        <Label Text="Zobacz wszystkie rezerwacje →"
                               FontSize="13" TextColor="#1565C0"
                               HorizontalOptions="End">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="Rezerwacje"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </VerticalStackLayout>
                </Frame>

                <!-- ── Powiadomienie iCal ── -->
                <Frame CornerRadius="14" Padding="14" HasShadow="False"
                       BackgroundColor="#E3F2FD">
                    <Grid ColumnDefinitions="32,*">
                        <Label Grid.Column="0" Text="ℹ️" FontSize="18" VerticalOptions="Start"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Synchronizacja iCal aktywna"
                                   FontSize="13" FontAttributes="Bold" TextColor="#1565C0"/>
                            <Label Text="Ostatnia synchronizacja: dziś o 08:12"
                                   FontSize="12" TextColor="#1976D2"/>
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <Label Text="yBook v2.0 · ybook.pl"
                       FontSize="11"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light=#B0BEC5, Dark=#455A64}"
                       Margin="0,4,0,16"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ═══════════════════════════════════════════════════════════
             OVERLAY
        ════════════════════════════════════════════════════════════ -->
        <BoxView Grid.Row="0"
                 Grid.RowSpan="2"
                 x:Name="DrawerOverlay"
                 BackgroundColor="#80000000"
                 IsVisible="False"
                 ZIndex="20">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnOverlayTapped"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- ═══════════════════════════════════════════════════════════
             PANEL BOCZNY (Navigation Drawer)
        ════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0"
              Grid.RowSpan="2"
              x:Name="DrawerPanel"
              WidthRequest="290"
              HorizontalOptions="Start"
              TranslationX="-290"
              ZIndex="30"
              BackgroundColor="{AppThemeBinding Light=#1A237E, Dark=#0D1442}">

            <ScrollView>
                <VerticalStackLayout Spacing="0">

                    <!-- ── Nagłówek drawera ── -->
                    <Grid HeightRequest="140"
                          BackgroundColor="#0D1442"
                          Padding="18,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Text="🏨" FontSize="36" VerticalOptions="End"/>
                        <Label Grid.Row="1"
                               Text="yBook"
                               FontSize="22" FontAttributes="Bold" TextColor="White"/>
                        <Label Grid.Row="2"
                               Text="System zarządzania obiektem"
                               FontSize="11" TextColor="#90CAF9"/>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#283593"/>

                    <!-- ════════════════════════════════════
                         BLOK 1: Widoki operacyjne
                    ═════════════════════════════════════ -->
                    <VerticalStackLayout Spacing="0" Padding="0,6,0,0">

                        <Grid Padding="18,13" BackgroundColor="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="📊" FontSize="17" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Pulpit"
                                   FontSize="14" TextColor="White" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="Pulpit"/>
                            </Grid.GestureRecognizers>
                        </Grid>

                        <Grid Padding="18,13" BackgroundColor="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="🛎️" FontSize="17" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Recepcja"
                                   FontSize="14" TextColor="White" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="Recepcja"/>
                            </Grid.GestureRecognizers>
                        </Grid>

                        <Grid Padding="18,13" BackgroundColor="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="🗓️" FontSize="17" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Kalendarz"
                                   FontSize="14" TextColor="White" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="Kalendarz"/>
                            </Grid.GestureRecognizers>
                        </Grid>

                        <Grid Padding="18,13" BackgroundColor="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="📅" FontSize="17" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Terminarz"
                                   FontSize="14" TextColor="White" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="Terminarz"/>
                            </Grid.GestureRecognizers>
                        </Grid>

                        <Grid Padding="18,13" BackgroundColor="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="🏧" FontSize="17" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Kasa"
                                   FontSize="14" TextColor="White" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="Kasa"/>
                            </Grid.GestureRecognizers>
                        </Grid>

                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" BackgroundColor="#283593" Margin="0,6"/>

                    <!-- ════════════════════════════════════
                         BLOK 2: CENY (rozwijalne)
                    ═════════════════════════════════════ -->

                    <Grid Padding="18,13" BackgroundColor="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="💲" FontSize="17" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Ceny"
                               FontSize="14" TextColor="#90CAF9" FontAttributes="Bold"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="2" x:Name="LblCenyArrow"
                               Text="▶" FontSize="11" TextColor="#90CAF9"
                               VerticalOptions="Center" HorizontalOptions="Center"/>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnGroupToggle" CommandParameter="Ceny"/>
                        </Grid.GestureRecognizers>
                    </Grid>

                    <VerticalStackLayout x:Name="MenuCenyGroup"
                                         IsVisible="False"
                                         BackgroundColor="#111B6B"
                                         Spacing="0">
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="📋" FontSize="14" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Cenniki"
                                   FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="Cenniki"/>
                            </Grid.GestureRecognizers>
                        </Grid>
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="➕" FontSize="14" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Usługi i opłaty dodatkowe"
                                   FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="UslugiOplaty"/>
                            </Grid.GestureRecognizers>
                        </Grid>
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="📦" FontSize="14" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Pakiety"
                                   FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="Pakiety"/>
                            </Grid.GestureRecognizers>
                        </Grid>
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="🏷️" FontSize="14" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Rabaty"
                                   FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="Rabaty"/>
                            </Grid.GestureRecognizers>
                        </Grid>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" BackgroundColor="#283593" Margin="0,6"/>

                    <!-- ════════════════════════════════════
                         BLOK 3: FINANSE (rozwijalne)
                    ═════════════════════════════════════ -->

                    <Grid Padding="18,13" BackgroundColor="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="💼" FontSize="17" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Finanse"
                               FontSize="14" TextColor="#90CAF9" FontAttributes="Bold"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="2" x:Name="LblFinanseArrow"
                               Text="▶" FontSize="11" TextColor="#90CAF9"
                               VerticalOptions="Center" HorizontalOptions="Center"/>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnGroupToggle" CommandParameter="Finanse"/>
                        </Grid.GestureRecognizers>
                    </Grid>

                    <VerticalStackLayout x:Name="MenuFinanseGroup"
                                         IsVisible="False"
                                         BackgroundColor="#111B6B"
                                         Spacing="0">
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="📄" FontSize="14" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Dokumenty"
                                   FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="Dokumenty"/>
                            </Grid.GestureRecognizers>
                        </Grid>
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="🏦" FontSize="14" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Konta finansowe"
                                   FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="KontaFinansowe"/>
                            </Grid.GestureRecognizers>
                        </Grid>
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="💳" FontSize="14" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Rejestr płatności"
                                   FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="RejestrPlatnosci"/>
                            </Grid.GestureRecognizers>
                        </Grid>
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="🏛️" FontSize="14" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Import MT940"
                                   FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMenuItemTapped" CommandParameter="ImportMT940"/>
                            </Grid.GestureRecognizers>
                        </Grid>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" BackgroundColor="#283593" Margin="0,6"/>

                    <!-- ════════════════════════════════════
                         BLOK 4: RAPORTY (rozwijalne)
                    ═════════════════════════════════════ -->

                    <Grid Padding="18,13" BackgroundColor="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="📈" FontSize="17" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Raporty"
                               FontSize="14" TextColor="#90CAF9" FontAttributes="Bold"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="2" x:Name="LblRaportyArrow"
                               Text="▶" FontSize="11" TextColor="#90CAF9"
                               VerticalOptions="Center" HorizontalOptions="Center"/>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnGroupToggle" CommandParameter="Raporty"/>
                        </Grid.GestureRecognizers>
                    </Grid>

                    <VerticalStackLayout x:Name="MenuRaportyGroup"
                                         IsVisible="False"
                                         BackgroundColor="#111B6B"
                                         Spacing="0">
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="🧾" FontSize="14" VerticalOptions="Center"/>
