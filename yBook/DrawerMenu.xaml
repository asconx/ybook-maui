<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="yBook.Controls.DrawerMenu">

    <!-- Wrapper: overlay + panel, rozciągnięty na cały ekran przez rodzica -->
    <Grid x:Name="DrawerRoot" IsVisible="False">

        <!-- Overlay -->
        <BoxView x:Name="DrawerOverlay"
                 BackgroundColor="#80000000"
                 Opacity="0">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnOverlayTapped"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Panel boczny -->
        <Grid x:Name="DrawerPanel"
              WidthRequest="290"
              HorizontalOptions="Start"
              TranslationX="-290"
              BackgroundColor="{AppThemeBinding Light=#1A237E, Dark=#0D1442}">

            <ScrollView>
                <VerticalStackLayout Spacing="0">

                    <!-- ── Nagłówek drawera ── -->
                    <Grid HeightRequest="140" BackgroundColor="#0D1442" Padding="18,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Text="🏨" FontSize="36" VerticalOptions="End"/>
                        <Label Grid.Row="1" Text="yBook"
                               FontSize="22" FontAttributes="Bold" TextColor="White"/>
                        <Label Grid.Row="2" Text="System zarządzania obiektem"
                               FontSize="11" TextColor="#90CAF9"/>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#283593"/>

                    <!-- ════ BLOK 1: Widoki operacyjne ════ -->
                    <VerticalStackLayout Spacing="0" Padding="0,6,0,0">
                        <Grid Padding="18,13" BackgroundColor="Transparent">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="📊" FontSize="17" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Pulpit" FontSize="14" TextColor="White" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="Pulpit"/></Grid.GestureRecognizers>
                        </Grid>
                        <Grid Padding="18,13" BackgroundColor="Transparent">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="🛎️" FontSize="17" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Recepcja" FontSize="14" TextColor="White" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="Recepcja"/></Grid.GestureRecognizers>
                        </Grid>
                        <Grid Padding="18,13" BackgroundColor="Transparent">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="🗓️" FontSize="17" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Kalendarz" FontSize="14" TextColor="White" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="Kalendarz"/></Grid.GestureRecognizers>
                        </Grid>
                        <Grid Padding="18,13" BackgroundColor="Transparent">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="📅" FontSize="17" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Terminarz" FontSize="14" TextColor="White" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="Terminarz"/></Grid.GestureRecognizers>
                        </Grid>
                        <Grid Padding="18,13" BackgroundColor="Transparent">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="🏧" FontSize="17" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Kasa" FontSize="14" TextColor="White" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="Kasa"/></Grid.GestureRecognizers>
                        </Grid>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" BackgroundColor="#283593" Margin="0,6"/>

                    <!-- ════ BLOK 2: CENY ════ -->
                    <Grid Padding="18,13" BackgroundColor="Transparent">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/></Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="💲" FontSize="17" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Ceny" FontSize="14" TextColor="#90CAF9" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Grid.Column="2" x:Name="LblCenyArrow" Text="▶" FontSize="11" TextColor="#90CAF9" VerticalOptions="Center" HorizontalOptions="Center"/>
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnGroupToggle" CommandParameter="Ceny"/></Grid.GestureRecognizers>
                    </Grid>
                    <VerticalStackLayout x:Name="MenuCenyGroup" IsVisible="False" BackgroundColor="#111B6B" Spacing="0">
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="📋" FontSize="14" VerticalOptions="Center"/><Label Grid.Column="1" Text="Cenniki" FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="Cenniki"/></Grid.GestureRecognizers></Grid>
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="➕" FontSize="14" VerticalOptions="Center"/><Label Grid.Column="1" Text="Usługi i opłaty dodatkowe" FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="UslugiOplaty"/></Grid.GestureRecognizers></Grid>
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="📦" FontSize="14" VerticalOptions="Center"/><Label Grid.Column="1" Text="Pakiety" FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="Pakiety"/></Grid.GestureRecognizers></Grid>
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="🏷️" FontSize="14" VerticalOptions="Center"/><Label Grid.Column="1" Text="Rabaty" FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="Rabaty"/></Grid.GestureRecognizers></Grid>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" BackgroundColor="#283593" Margin="0,6"/>

                    <!-- ════ BLOK 3: FINANSE ════ -->
                    <Grid Padding="18,13" BackgroundColor="Transparent">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/></Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="💼" FontSize="17" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Finanse" FontSize="14" TextColor="#90CAF9" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Grid.Column="2" x:Name="LblFinanseArrow" Text="▶" FontSize="11" TextColor="#90CAF9" VerticalOptions="Center" HorizontalOptions="Center"/>
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnGroupToggle" CommandParameter="Finanse"/></Grid.GestureRecognizers>
                    </Grid>
                    <VerticalStackLayout x:Name="MenuFinanseGroup" IsVisible="False" BackgroundColor="#111B6B" Spacing="0">
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="📄" FontSize="14" VerticalOptions="Center"/><Label Grid.Column="1" Text="Dokumenty" FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="Dokumenty"/></Grid.GestureRecognizers></Grid>
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="🏦" FontSize="14" VerticalOptions="Center"/><Label Grid.Column="1" Text="Konta finansowe" FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="KontaFinansowe"/></Grid.GestureRecognizers></Grid>
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="💳" FontSize="14" VerticalOptions="Center"/><Label Grid.Column="1" Text="Rejestr płatności" FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="RejestrPlatnosci"/></Grid.GestureRecognizers></Grid>
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="🏛️" FontSize="14" VerticalOptions="Center"/><Label Grid.Column="1" Text="Import MT940" FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="ImportMT940"/></Grid.GestureRecognizers></Grid>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" BackgroundColor="#283593" Margin="0,6"/>

                    <!-- ════ BLOK 4: RAPORTY ════ -->
                    <Grid Padding="18,13" BackgroundColor="Transparent">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/></Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="📈" FontSize="17" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Raporty" FontSize="14" TextColor="#90CAF9" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Grid.Column="2" x:Name="LblRaportyArrow" Text="▶" FontSize="11" TextColor="#90CAF9" VerticalOptions="Center" HorizontalOptions="Center"/>
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnGroupToggle" CommandParameter="Raporty"/></Grid.GestureRecognizers>
                    </Grid>
                    <VerticalStackLayout x:Name="MenuRaportyGroup" IsVisible="False" BackgroundColor="#111B6B" Spacing="0">
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="🧾" FontSize="14" VerticalOptions="Center"/><Label Grid.Column="1" Text="Raport usług i opłat" FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="RaportUslug"/></Grid.GestureRecognizers></Grid>
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="📊" FontSize="14" VerticalOptions="Center"/><Label Grid.Column="1" Text="Raport finansowy" FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="RaportFinansowy"/></Grid.GestureRecognizers></Grid>
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="🚫" FontSize="14" VerticalOptions="Center"/><Label Grid.Column="1" Text="Raport niedojazdów" FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="RaportNiedojazdow"/></Grid.GestureRecognizers></Grid>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" BackgroundColor="#283593" Margin="0,6"/>

                    <!-- ════ BLOK 5: Rezerwacje i klienci ════ -->
                    <VerticalStackLayout Spacing="0">
                        <Grid Padding="18,13" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="📅" FontSize="17" VerticalOptions="Center"/><Label Grid.Column="1" Text="ICalendar" FontSize="14" TextColor="White" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="ICalendar"/></Grid.GestureRecognizers></Grid>
                        <Grid Padding="18,13" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="📝" FontSize="17" VerticalOptions="Center"/><Label Grid.Column="1" Text="Rezerwacje" FontSize="14" TextColor="White" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="RezerwacjeOnline"/></Grid.GestureRecognizers></Grid>
                        <Grid Padding="18,13" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="👥" FontSize="17" VerticalOptions="Center"/><Label Grid.Column="1" Text="Klienci" FontSize="14" TextColor="White" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="Klienci"/></Grid.GestureRecognizers></Grid>
                        <Grid Padding="18,13" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="💬" FontSize="17" VerticalOptions="Center"/><Label Grid.Column="1" Text="Grupowy SMS" FontSize="14" TextColor="White" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="GrupowySMS"/></Grid.GestureRecognizers></Grid>
                        <Grid Padding="18,13" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="🗄️" FontSize="17" VerticalOptions="Center"/><Label Grid.Column="1" Text="Archiwum" FontSize="14" TextColor="White" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="Archiwum"/></Grid.GestureRecognizers></Grid>
                        <Grid Padding="18,13" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="🌐" FontSize="17" VerticalOptions="Center"/><Label Grid.Column="1" Text="Rezerwacje online" FontSize="14" TextColor="White" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="Rezerwacje"/></Grid.GestureRecognizers></Grid>
                        <Grid Padding="18,13" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="📜" FontSize="17" VerticalOptions="Center"/><Label Grid.Column="1" Text="Rejestr akcji" FontSize="14" TextColor="White" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="RejestrAkcji"/></Grid.GestureRecognizers></Grid>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" BackgroundColor="#283593" Margin="0,6"/>

                    <!-- ════ BLOK 6: BLOKADY ════ -->
                    <Grid Padding="18,13" BackgroundColor="Transparent">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/></Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="🔒" FontSize="17" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Blokady" FontSize="14" TextColor="#90CAF9" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Grid.Column="2" x:Name="LblBlokadyArrow" Text="▶" FontSize="11" TextColor="#90CAF9" VerticalOptions="Center" HorizontalOptions="Center"/>
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnGroupToggle" CommandParameter="Blokady"/></Grid.GestureRecognizers>
                    </Grid>
                    <VerticalStackLayout x:Name="MenuBlokadyGroup" IsVisible="False" BackgroundColor="#111B6B" Spacing="0">
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="🔐" FontSize="14" VerticalOptions="Center"/><Label Grid.Column="1" Text="Zbiorcze blokady" FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="ZbiorczeBlokady"/></Grid.GestureRecognizers></Grid>
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="🔄" FontSize="14" VerticalOptions="Center"/><Label Grid.Column="1" Text="Przyjazd / Wyjazd" FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="PrzyjazdWyjazd"/></Grid.GestureRecognizers></Grid>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" BackgroundColor="#283593" Margin="0,6"/>

                    <!-- ════ BLOK 7: USTAWIENIA ════ -->
                    <Grid Padding="18,13" BackgroundColor="Transparent">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/></Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="⚙️" FontSize="17" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Ustawienia" FontSize="14" TextColor="#90CAF9" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Grid.Column="2" x:Name="LblUstawieniaArrow" Text="▶" FontSize="11" TextColor="#90CAF9" VerticalOptions="Center" HorizontalOptions="Center"/>
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnGroupToggle" CommandParameter="Ustawienia"/></Grid.GestureRecognizers>
                    </Grid>
                    <VerticalStackLayout x:Name="MenuUstawieniaGroup" IsVisible="False" BackgroundColor="#111B6B" Spacing="0">
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="🏨" FontSize="14" VerticalOptions="Center"/><Label Grid.Column="1" Text="Dane obiektu" FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="DaneObiektu"/></Grid.GestureRecognizers></Grid>
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="🛏️" FontSize="14" VerticalOptions="Center"/><Label Grid.Column="1" Text="Pokoje i apartamenty" FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="Pokoje"/></Grid.GestureRecognizers></Grid>
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="🔗" FontSize="14" VerticalOptions="Center"/><Label Grid.Column="1" Text="Synchronizacja iCal" FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="SyncICal"/></Grid.GestureRecognizers></Grid>
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="👤" FontSize="14" VerticalOptions="Center"/><Label Grid.Column="1" Text="Użytkownicy i dostępy" FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="Uzytkownicy"/></Grid.GestureRecognizers></Grid>
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="📧" FontSize="14" VerticalOptions="Center"/><Label Grid.Column="1" Text="Szablony e-mail / SMS" FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="Szablony"/></Grid.GestureRecognizers></Grid>
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="🧾" FontSize="14" VerticalOptions="Center"/><Label Grid.Column="1" Text="Konfiguracja faktur" FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="KonfFaktur"/></Grid.GestureRecognizers></Grid>
                        <Grid Padding="42,11,18,11" BackgroundColor="Transparent"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Label Grid.Column="0" Text="🔔" FontSize="14" VerticalOptions="Center"/><Label Grid.Column="1" Text="Powiadomienia" FontSize="13" TextColor="#CFD8DC" VerticalOptions="Center"/><Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="Powiadomienia"/></Grid.GestureRecognizers></Grid>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" BackgroundColor="#283593" Margin="0,8"/>

                    <!-- Wyloguj -->
                    <Grid Padding="18,14,18,28" BackgroundColor="Transparent">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="🚪" FontSize="17" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Wyloguj się" FontSize="14" TextColor="#EF9A9A" VerticalOptions="Center"/>
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="Logout"/></Grid.GestureRecognizers>
                    </Grid>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>

</ContentView>
