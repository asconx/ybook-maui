<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ctrl="clr-namespace:yBook.Controls"
             x:Class="yBook.Views.Powiadomienia.PowiadomieniaPage"
             NavigationPage.HasNavigationBar="False">

	<Grid RowDefinitions="60,*">

		<ctrl:PageHeader Grid.Row="0"
                         Title="Powiadomienia"
                         Icon="⛔"
                         ShowBack="True"/>

		<VerticalStackLayout Grid.Row="1" Padding="16">

			<CollectionView x:Name="NotifList">
				<CollectionView.ItemTemplate>
					<DataTemplate>
						<Frame Padding="16" Margin="0,0,0,10">
							<VerticalStackLayout>
								<Button Text="Edytuj" Clicked="EditNotif"/>
								<Button Text="Usun" Clicked="DeleteNotif"/>
								<Label Text="{Binding Nazwa}" FontAttributes="Bold"/>
								<Label Text="{Binding Typ}"/>
								<Label Text="{Binding Rodzaj}" FontSize="12"/>

							</VerticalStackLayout>

						</Frame>
					</DataTemplate>
				</CollectionView.ItemTemplate>
			</CollectionView>

			<Button Text="Dodaj" Clicked="ShowNotifForm"/>

		</VerticalStackLayout>

	</Grid>
</ContentPage>
