<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ctrl="clr-namespace:yBook.Controls"
             x:Class="yBook.Views.ICalendar.ICalendarPage"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="60,Auto,*"
          BackgroundColor="{AppThemeBinding Light=#F4F6F9, Dark=#121212}">

        <ctrl:PageHeader Grid.Row="0"
                         Title="ICalendar"
                         Icon="📅"
                         ShowBack="True"
                         x:Name="Header"/>

        <HorizontalStackLayout Grid.Row="1" Padding="12" Spacing="12">

            <Label Text="Synchronizacje"
                   FontAttributes="Bold"
                   VerticalOptions="Center"/>

            <Label x:Name="LblCount"
                   Text="0"
                   VerticalOptions="Center"/>

            <Button Text="Dodaj"
                    Clicked="OnDodajClicked"/>

        </HorizontalStackLayout>
        

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Items}">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*,Auto,Auto" Padding="10">

                        <Label Text="{Binding Name}"
                               VerticalOptions="Center"/>

                        <Button Text="Edytuj"
                                Grid.Column="1"
                                Clicked="OnEditClicked"/>

                        <Button Text="Usuń"
                                Grid.Column="2"
                                Clicked="OnDeleteClicked"/>

                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>