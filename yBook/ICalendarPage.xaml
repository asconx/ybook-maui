<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ctrl="clr-namespace:yBook.Controls"
             x:Class="yBook.Views.ICalendar.ICalendarPage"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <Style x:Key="ColHeader" TargetType="Label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#555555, Dark=#90A4AE}"/>
            <Setter Property="VerticalOptions" Value="Center"/>
            <Setter Property="LineBreakMode" Value="TailTruncation"/>
        </Style>
        <Style x:Key="ColCell" TargetType="Label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#1A1A1A, Dark=#ECEFF1}"/>
            <Setter Property="VerticalOptions" Value="Center"/>
            <Setter Property="LineBreakMode" Value="TailTruncation"/>
        </Style>
        <Style x:Key="ColCellBold" TargetType="Label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="VerticalOptions" Value="Center"/>
            <Setter Property="LineBreakMode" Value="TailTruncation"/>
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="60,Auto,Auto,*"
          BackgroundColor="{AppThemeBinding Light=#F4F6F9, Dark=#121212}">

        <ctrl:PageHeader Grid.Row="0"
                         Title="ICalendar"
                         Icon="📅"
                         ShowBack="True"
                         x:Name="Header"/>
        <ScrollView Grid.Row="1"
            Orientation="Horizontal"
            HorizontalScrollBarVisibility="Never"
            VerticalScrollBarVisibility="Never">

            <HorizontalStackLayout Spacing="12"
                           Padding="12,10"
                           VerticalOptions="Center">

                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                    <Label Text="Synchronizacje"
                   FontSize="15"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#ECEFF1}"/>
                    <Border StrokeShape="RoundRectangle 10"
                    BackgroundColor="#F5A623"
                    Stroke="Transparent"
                    Padding="6,2"
                    VerticalOptions="Center">
                        <Label x:Name="LblCount"
                       Text="0"
                       FontSize="11"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"/>
                    </Border>
                </HorizontalStackLayout>

                <Border StrokeShape="RoundRectangle 20"
                BackgroundColor="{AppThemeBinding Light=#1A1A1A, Dark=#ECEFF1}"
                Stroke="Transparent"
                Padding="18,8"
                VerticalOptions="Center">
                    <Label Text="dodaj"
                   FontSize="13"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=White, Dark=#1A1A1A}"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDodajClicked"/>
                    </Border.GestureRecognizers>
                </Border>

                <BoxView Color="Transparent"
                 HorizontalOptions="FillAndExpand"
                 VerticalOptions="Center"/>



            </HorizontalStackLayout>
        </ScrollView>
        <CollectionView 
            Grid.Row="2">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <HorizontalStackLayout>
                        <Button/>
                        <Button/>
                        <Label/>
                    </HorizontalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

            <ctrl:DrawerMenu Grid.Row="0" Grid.RowSpan="4"
                         x:Name="Drawer" ZIndex="50"/>

    </Grid>
</ContentPage>
